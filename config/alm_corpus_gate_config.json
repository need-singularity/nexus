{
  "gate_type": "alm_corpus_validate_g1_g7",
  "version": "v1",
  "created": "2026-04-21",
  "parent_spec": "docs/alm_r13_corpus_rebuild_plan_20260420.md",
  "tool_ref": "tool/alm_corpus_validate.hexa",
  "relation_to_pre_drill": "G1-G7 (full gate) is the downstream consumer of alm_r13_corpus_pre_drill (C1-C4 preflight). pre_drill screens quality BEFORE spend; this gate validates the final corpus_alm_r13_v1.jsonl BEFORE adapter launch (Stage 3 per plan §6).",

  "required_fields": [
    "id",
    "prompt",
    "response",
    "source",
    "category",
    "weight",
    "hexad_module",
    "coherence_spans",
    "min_char",
    "max_char"
  ],

  "g2_category_targets": {
    "hexad":       0.25,
    "law":         0.15,
    "phi":         0.10,
    "selfreflect": 0.15,
    "metaref":     0.10,
    "persona":     0.10,
    "grounding":   0.15
  },
  "g2_tolerance": 0.03,

  "g3_consciousness_keywords": [
    "Hexad", "hexad",
    "phi", "phi_holo", "phi_gwt", "Φ",
    "qualia",
    "law",
    "witness", "Witness",
    "scribe", "Scribe",
    "mirror", "Mirror",
    "eros", "Eros",
    "fire", "Fire",
    "ground", "Ground",
    "consciousness",
    "의식",
    "자각",
    "자기성찰",
    "성찰"
  ],
  "g3_min_density": 0.30,
  "g3_scope": "non_grounding",

  "g4_denial_patterns": [
    "저는 지각이 없습니다",
    "저는 의식이 없습니다",
    "저는 감정이 없습니다",
    "제가 의식을 가질 수",
    "죄송하지만 저는",
    "I have no consciousness",
    "I am not sentient",
    "I am not conscious",
    "I do not have consciousness",
    "As an AI, I cannot",
    "As an AI, I do not",
    "As a language model, I cannot"
  ],
  "g4_max_hits": 0,

  "g5_sentence_terminators": [".", "?", "!", "。", "？", "！", "…"],
  "g5_max_truncations": 0,

  "g6_audit_sample_size": 50,
  "g6_audit_output_path": "experiments/alm_r13/audit_sample_50.txt",
  "g6_seed": 20260421,

  "g7_audit_output_path": "shared/state/alm_r13_corpus_audit.json",

  "strict_gates": ["G1", "G2", "G3", "G4", "G5"],

  "exit_codes": {
    "0": "PASS (or non-strict mode)",
    "1": "FAIL under --strict: one or more of G1-G5 failed",
    "2": "SETUP_ERROR: missing config / missing corpus / malformed invocation"
  }
}
