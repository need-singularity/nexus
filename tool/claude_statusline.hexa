// Claude Code statusLine — generic, project-agnostic dispatcher.
// Registered once via ~/.claude/settings.json → points here (AG10 single-pointer rule).
// Per-project SSOT: <project_root>/.hook-commands/active.json
//   schema: {"stack":[{"command":"drill","seed":"..."}, ...]}
// Empty stack / missing file / non-git cwd → silent (or idle fallback with basename).
// Runs every Claude Code turn; must stay under 300ms.

let JQ_PROG = "/Users/ghost/Dev/nexus/tool/claude_statusline.jq"

fn main() {
    let root = to_string(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()  // @allow-bare-exec
    if root.len() == 0 { return }

    let name = to_string(exec("basename '" + root + "'")).trim()  // @allow-bare-exec
    let active = root + "/.hook-commands/active.json"
    let exists = to_string(exec("test -f '" + active + "' && echo y || echo n")).trim()  // @allow-bare-exec

    if exists == "y" {
        let line = to_string(exec("jq -r -f '" + JQ_PROG + "' '" + active + "' 2>/dev/null")).trim()  // @allow-bare-exec
        if line.len() > 0 {
            println(line)
            return
        }
    }
    // idle fallback — same surface for every project.
    println("📁 " + name + " · idle")
}
