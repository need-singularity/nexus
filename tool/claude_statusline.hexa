// Claude Code statusLine dispatcher — CWD-based router to per-project status sources.
// Registered via single pointer in ~/.claude/settings.json (AG10 compliant — no per-project .claude/settings.json).
// SSOT: $NEXUS/rules/airgenome.json#AG10.
// Runs every Claude Code turn; keep fast (no hexa startup cost beyond POSIX exec forks).

fn main() {
    // Detect project root via git (POSIX, no path-library dep).
    let root = to_string(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()  // @allow-bare-exec
    if root.len() == 0 { return }

    let name = to_string(exec("basename '" + root + "'")).trim()  // @allow-bare-exec

    if name == "airgenome" {
        let bin = root + "/bin/airgenome"
        let exists = to_string(exec("test -x '" + bin + "' && echo y || echo n")).trim()  // @allow-bare-exec
        if exists == "y" {
            let line = to_string(exec(bin + " status-line 2>/dev/null")).trim()  // @allow-bare-exec
            if line.len() > 0 { println(line) }
        }
        return
    }
    // default: silent — add other projects as they gain status-line commands.
}
