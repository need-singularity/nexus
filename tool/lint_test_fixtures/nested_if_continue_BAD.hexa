// B1 BAD fixture: outer `if { ... if { ... continue ... } ... }`
// inner `continue` skips outer's `i = i + 1` tail → infinite loop.
// Lint MUST catch this (exit 1).
fn _scan_bad(rows: array) -> bool {
    let mut i = 0
    let n = len(rows)
    while i < n {
        let row = rows[i]
        if len(row) > 0 {
            if row[0] == "skip" {
                continue
            }
            // do work
            let _x = row[0]
        }
        i = i + 1
    }
    return true
}
