// B1 GOOD fixture: flat-guard idiom — single-line `if cond { i = i + 1; continue }`
// at the outer scope. No nested-if-block-with-continue. Lint MUST accept (exit 0).
fn _scan_good(rows: array) -> bool {
    let mut i = 0
    let n = len(rows)
    while i < n {
        let row = rows[i]
        if len(row) == 0 { i = i + 1; continue }
        if row[0] == "skip" { i = i + 1; continue }
        // do work
        let _x = row[0]
        i = i + 1
    }
    return true
}
