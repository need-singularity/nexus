// ═══════════════════════════════════════════════════════════════════════
// 패턴 4: Lazy Lens Load — 1054 렌즈 지연 로딩
// ═══════════════════════════════════════════════════════════════════════
// 전체 로딩 대신 도메인별 필요한 것만 로드.

struct LazyRegistry {
    loaded: bool,
    all_names: [string],        // 메타데이터만
    loaded_entries: [string],   // 실제 로드된 lens 이름
    max_loaded: int             // LRU cap
}

fn lazy_registry_new(cap) {
    return LazyRegistry {
        loaded: false,
        all_names: [],
        loaded_entries: [],
        max_loaded: cap
    }
}

// 메타데이터(이름만) 먼저 로드.
fn lazy_load_names(reg) {
    if reg.loaded { return reg }
    // TODO: 파일 한번에 훑어서 이름 리스트만
    let mut next = reg
    next.loaded = true
    return next
}

// 실제 렌즈 on-demand 로드.
fn lazy_get_lens(reg, name) {
    // 1. loaded_entries에 있으면 반환 (hit)
    // 2. 없으면 로드 + LRU 관리
    let mut i = 0
    while i < len(reg.loaded_entries) {
        if reg.loaded_entries[i] == name { return (reg, "HIT") }
        i = i + 1
    }
    // MISS: 로드 + 캐시 추가
    let mut next = reg
    if len(next.loaded_entries) >= next.max_loaded {
        // evict oldest (index 0)
        let mut new_cache = []
        let mut j = 1
        while j < len(next.loaded_entries) {
            new_cache = new_cache.push(next.loaded_entries[j])
            j = j + 1
        }
        next.loaded_entries = new_cache
    }
    next.loaded_entries = next.loaded_entries.push(name)
    return (next, "LOADED")
}

// ═══════════════════════════════════════════════════════════════════════
// 패턴 5: Memoized Classify — 동일 입력 중복 계산 방지
// ═══════════════════════════════════════════════════════════════════════

struct ClassifyCache {
    keys: [int],               // (text_hash, ps_hash) 결합 key
    values: [string],          // sector 이름
    confidences: [float],
    capacity: int
}

fn classify_cache_new(cap) {
    return ClassifyCache { keys: [], values: [], confidences: [], capacity: cap }
}

fn classify_key(text, ps) {
    let th = content_hash(text)
    let mut ps_str = ""
    let mut i = 0
    while i < len(ps.primes) {
        ps_str = ps_str + to_string(ps.primes[i]) + ","
        i = i + 1
    }
    let ph = content_hash(ps_str)
    return th * 2654435761 + ph                    // combine
}

fn cache_lookup(cache, key) {
    let mut i = 0
    while i < len(cache.keys) {
        if cache.keys[i] == key { return (true, cache.values[i], cache.confidences[i]) }
        i = i + 1
    }
    return (false, "", 0.0)
}

fn cache_insert(cache, key, sector, conf) {
    let mut next = cache
    if len(next.keys) >= next.capacity {
        // LRU evict (간단히 index 0)
        let mut nk = []
        let mut nv = []
        let mut nc = []
        let mut j = 1
        while j < len(next.keys) {
            nk = nk.push(next.keys[j])
            nv = nv.push(next.values[j])
            nc = nc.push(next.confidences[j])
            j = j + 1
        }
        next.keys = nk
        next.values = nv
        next.confidences = nc
    }
    next.keys = next.keys.push(key)
    next.values = next.values.push(sector)
    next.confidences = next.confidences.push(conf)
    return next
}

// ═══════════════════════════════════════════════════════════════════════
// 자원 절감 추정
// ═══════════════════════════════════════════════════════════════════════
// 패턴 1 (dirty flag):      ~200μs × N meta_loop 호출 제거
// 패턴 2 (content hash):    1 KB 쓰기 × N → hash 비교 후 skip
// 패턴 3 (writeback):       ρ plateau 탈출 (기능적 개선)
// 패턴 4 (lazy load):       1054 렌즈 → ~20 실사용 (98% 메모리 절감)
// 패턴 5 (memoize):         N회 classify → K회 (K << N, 예: 90% cache hit)
