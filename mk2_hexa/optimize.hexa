// mk2_hexa/optimize.hexa — 성능/자원 최적화 패턴 (draft)
//
// 실측 병목 (exhaustion loop 21 iter):
//   1. custom_lenses.jsonl redundant write: 매 meta_loop 호출마다 동일 바이트 쓰기 (~200μs/호출)
//   2. bridge evolve 74-route churn: 유지비용 (실질 돌파 0)
//   3. alien-index writeback 부재: ρ=0 고정, disc=66 불변
//   4. --meta-cycles CLI 버그: 사용자 인자 무시 (meta=1 로 고정)
//   5. 1054 렌즈 로딩: 매 프로세스 실행시 전체 스캔
//
// 이 파일은 위 5개에 대한 HEXA 설계 — 런타임 0 비용 (디자인 레이어).

// ═══════════════════════════════════════════════════════════════════════
// 패턴 1: Dirty Flag — redundant write 제거
// ═══════════════════════════════════════════════════════════════════════

struct DirtyTracked {
    data: [string],             // 저장 대상
    dirty: bool,                // 마지막 save 이후 변경 있었나
    last_hash: int              // 변경 감지용 fingerprint
}

fn dirty_new() {
    return DirtyTracked { data: [], dirty: false, last_hash: 0 }
}

fn dirty_mark_modified(dt) {
    let mut next = dt
    next.dirty = true
    return next
}

// 쓰기 시도: dirty=false면 no-op. 실제로 쓰면 flag 해제.
fn dirty_save_if_needed(dt, path) {
    if !dt.dirty { return dt }                   // SKIP — 절감
    // TODO(hexa-stdlib): file_write(path, serialize(dt.data))
    let mut next = dt
    next.dirty = false
    return next
}

// ═══════════════════════════════════════════════════════════════════════
// 패턴 2: Content Hash Guard — 동일 바이트 보호
// ═══════════════════════════════════════════════════════════════════════

// 간이 FNV-1a 32bit. 실제 구현은 stdlib 대기.
fn content_hash(s) {
    let mut h = 2166136261
    let bytes = s.chars()
    let mut i = 0
    while i < len(bytes) {
        h = h ^ to_int(bytes[i])
        h = (h * 16777619) % 4294967296
        i = i + 1
    }
    return h
}

// save 전에 현재 직렬화 해시 vs 디스크 해시 비교.
fn save_if_content_changed(current_data, path, prev_hash) {
    let serialized = serialize_list(current_data)    // TODO(hexa-stdlib)
    let cur_hash = content_hash(serialized)
    if cur_hash == prev_hash { return prev_hash }    // SKIP
    // TODO(hexa-stdlib): file_write(path, serialized)
    return cur_hash
}

