    let lenses = []
    let lenses = lenses.push("consciousness")
    let lenses = lenses.push("gravity")
    let lenses = lenses.push("topology")
    let lenses = lenses.push("thermo")
    let lenses = lenses.push("wave")
    let lenses = lenses.push("evolution")
    let lenses = lenses.push("info")
    let lenses = lenses.push("quantum")
    let lenses = lenses.push("em")
    let lenses = lenses.push("ruler")
    let lenses = lenses.push("triangle")
    let lenses = lenses.push("compass")
    let lenses = lenses.push("mirror")
    let lenses = lenses.push("scale")
    let lenses = lenses.push("causal")
    let lenses = lenses.push("quantum_microscope")
    let lenses = lenses.push("stability")
    let lenses = lenses.push("network")
    let lenses = lenses.push("memory")
    let lenses = lenses.push("recursion")
    let lenses = lenses.push("boundary")
