// mk2_hexa/native/forge.hexa — LLM 자기 압축 엔진 (token-forge)
// compress: 텍스트 → 반복 자기 압축
// anvil: 압축본 의미 보존 검증 (Q&A + 헤더 커버리지)
// profiler: 섹션별 정보 밀도 프로파일링

// ──────────────────────────────────────
// 설정 상수
// ──────────────────────────────────────

comptime const default_rounds = 5
comptime const convergence_threshold = 0.01
comptime const qa_total = 5
comptime const qa_pass_threshold = 0.05
comptime const section_min_chars = 20
comptime const density_high = 0.35
comptime const density_med = 0.20
comptime const density_low = 0.10

// ──────────────────────────────────────
// 압축 프롬프트
// ──────────────────────────────────────

comptime const compress_prompt = "You are a compression engine. Compress the following document into the MINIMUM number of tokens that YOU (Claude) can later decode back to the full original meaning.\n\nRules:\n- The compressed output is ONLY for LLM consumption, not humans\n- Use any symbols, abbreviations, shorthand, unicode, or encoding you want\n- Preserve ALL semantic content\n- Structure markers can be replaced with minimal delimiters\n- Repeated patterns should use the shortest possible reference\n- Output ONLY the compressed text, nothing else\n\nDocument:\n---\n"

comptime const recompress_prompt = "You previously compressed a document into this form:\n\n---\n"

comptime const recompress_suffix = "\n---\n\nCompress it FURTHER. Find any remaining redundancy and eliminate it.\nSame rules: minimum tokens, preserve all meaning, LLM-only consumption.\nOutput ONLY the re-compressed text, nothing else."

comptime const qa_prompt_prefix = "You will test whether a compressed document preserves the meaning of the original.\n\nORIGINAL DOCUMENT:\n---\n"
comptime const qa_prompt_mid = "\n---\n\nCOMPRESSED DOCUMENT:\n---\n"
comptime const qa_prompt_suffix = "\n---\n\nGenerate exactly 5 factual questions about the original document. For each question, answer it using ONLY the compressed document. Then judge if the compressed-based answer matches the original meaning.\n\nOutput format (exactly 5 lines, no other text):\nQ1 | A: [answer from compressed] | PASS or FAIL\nQ2 | A: [answer from compressed] | PASS or FAIL\nQ3 | A: [answer from compressed] | PASS or FAIL\nQ4 | A: [answer from compressed] | PASS or FAIL\nQ5 | A: [answer from compressed] | PASS or FAIL"

comptime const section_compress_prompt = "Compress this to minimum tokens only you can decode. Preserve ALL meaning. Output ONLY compressed text:\n\n---\n"

// ──────────────────────────────────────
// 데이터 구조체
// ──────────────────────────────────────

// 1라운드 압축 결과
struct RoundResult {
    round: int,
    chars: int,
    r: float,       // 압축률 = compressed / original
    delta_r: float  // 이전 라운드 대비 변화량
}

// 전체 압축 리포트
struct ForgeReport {
    run_id: string,
    original_chars: int,
    final_r: float,
    final_chars: int,
    rounds_count: int,
    converged_at: int  // -1 = 미수렴
}

// anvil 검증 결과
struct VerifyResult {
    header_score: float,  // 헤더 커버리지 비율
    qa_score: float,      // Q&A 정답률
    loss: float,          // 의미 손실도 = 1 - qa_score
    pass: bool            // loss <= 0.05 → PASS
}

// 섹션별 정보 밀도 결과
struct SectionResult {
    name: string,
    original_chars: int,
    compressed_chars: int,
    r: float,
    grade: string  // "HIGH", "MED", "LOW", "SKIP"
}

// 전체 프로파일 리포트
struct ProfileReport {
    total_original: int,
    total_compressed: int,
    overall_r: float,
    skip_count: int,
    skip_chars: int,
    section_count: int
}

// ──────────────────────────────────────
// 유틸리티 함수
// ──────────────────────────────────────

// 소수점 4자리 반올림
pure fn round4(x: float) -> float {
    let scaled = x * 10000.0
    // 정수 변환 후 복원
    let i = to_int(scaled + 0.5)
    to_float(i) / 10000.0
}

pure fn abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

// 문자열 길이 (chars)
pure fn str_len(s: string) -> int {
    len(s)
}

// ──────────────────────────────────────
// claude CLI 호출 (외부 프로세스)
// ──────────────────────────────────────

fn llm_call(prompt: string) -> string {
    // claude CLI를 통한 LLM 호출
    let result = exec("claude -p '" + prompt + "'")
    return result
}

fn find_claude_cli() -> string {
    let which_result = exec("which claude 2>/dev/null")
    if str_len(which_result) > 0 {
        return which_result
    }
    // 알려진 경로 탐색
    let home = exec("printenv HOME")
    let paths = [ home + "/.local/bin/claude", "/usr/local/bin/claude", "/opt/homebrew/bin/claude" ]
    let mut i = 0
    while i < 3 {
        if file_exists(paths[i]) {
            return paths[i]
        }
        i = i + 1
    }
    return ""
}

// ──────────────────────────────────────
// compress: 반복 자기 압축
// ──────────────────────────────────────

fn forge_compress(text: string, rounds: int, threshold: float) -> ForgeReport {
    let original_chars = str_len(text)
    let run_id = "forge_" + to_string(timestamp())
    let mut current = text
    let mut prev_r = 1.0
    let mut converged_at = -1
    let mut final_r = 1.0
    let mut final_chars = original_chars
    let mut rounds_done = 0

    let mut i = 0
    while i < rounds {
        // 프롬프트 구성
        let prompt = if i == 0 {
            compress_prompt + current + "\n---"
        } else {
            recompress_prompt + current + recompress_suffix
        }

        println("  Round " + to_string(i + 1) + "/" + to_string(rounds) + ": 압축 중...")
        let compressed = llm_call(prompt)
        let comp_chars = str_len(compressed)
        let r = round4(to_float(comp_chars) / to_float(original_chars))
        let delta_r = if i == 0 { 1.0 } else { abs_f(r - prev_r) }

        println("  [Round " + to_string(i) + "] " + to_string(comp_chars) + " chars | r=" + to_string(r) + " | dr=" + to_string(delta_r))

        // 라운드 결과 파일 저장
        let round_path = "bench/runs/" + run_id + "/round_" + to_string(i) + ".tf"
        write_file(round_path, compressed)

        if i > 0 && delta_r < threshold {
            println("  * 수렴 달성 (dr < " + to_string(threshold) + ") at round " + to_string(i))
            converged_at = i
            final_r = r
            final_chars = comp_chars
            rounds_done = i + 1
            i = rounds  // break
        } else {
            prev_r = r
            final_r = r
            final_chars = comp_chars
            current = compressed
            rounds_done = i + 1
            i = i + 1
        }
    }

    ForgeReport {
        run_id: run_id,
        original_chars: original_chars,
        final_r: final_r,
        final_chars: final_chars,
        rounds_count: rounds_done,
        converged_at: converged_at
    }
}

// 기본 설정으로 압축
fn forge_compress_default(text: string) -> ForgeReport {
    forge_compress(text, default_rounds, convergence_threshold)
}

// ──────────────────────────────────────
// anvil: 압축 검증
// ──────────────────────────────────────

// 헤더 커버리지 측정: 원본의 ## 헤더 중 압축본에 보존된 비율
pure fn header_coverage_score(original: string, compressed: string) -> float {
    // 간이 구현: ## 줄 수 대비 압축본에서 매칭되는 비율
    // 실제 구현은 라인 파싱 필요 — 여기서는 헤더 존재 여부만 확인
    let has_headers = contains(original, "## ")
    if !has_headers { return 1.0 }
    // 원본 헤더 첫 20자를 압축본에서 검색
    // hexa에서는 단순화된 구현
    0.5
}

fn anvil_verify(compressed: string, original: string) -> VerifyResult {
    // 1. 헤더 커버리지
    let header_score = header_coverage_score(original, compressed)
    println("  헤더 커버리지: " + to_string(header_score))

    // 2. Q&A 테스트 (LLM 기반)
    let prompt = qa_prompt_prefix + original + qa_prompt_mid + compressed + qa_prompt_suffix
    let qa_result = llm_call(prompt)
    println(qa_result)

    // PASS 횟수 카운트
    let pass_count = count_occurrences(qa_result, "PASS")
    let qa_score = round4(to_float(pass_count) / to_float(qa_total))
    let loss = round4(1.0 - qa_score)
    let passed = loss <= qa_pass_threshold

    println("")
    println("=== 결과 ===")
    println("Q&A 정답률:    " + to_string(pass_count) + "/" + to_string(qa_total) + " = " + to_string(qa_score))
    println("의미 손실도 L: " + to_string(loss))
    if passed {
        println("판정: PASS (L <= " + to_string(qa_pass_threshold) + ")")
    } else {
        println("판정: FAIL (L > " + to_string(qa_pass_threshold) + ")")
    }

    VerifyResult {
        header_score: header_score,
        qa_score: qa_score,
        loss: loss,
        pass: passed
    }
}

// ──────────────────────────────────────
// profiler: 섹션별 정보 밀도
// ──────────────────────────────────────

// 정보 밀도 등급 판정
pure fn density_grade(r: float) -> string {
    if r > density_high { "HIGH" }
    else if r > density_med { "MED" }
    else if r > density_low { "LOW" }
    else { "SKIP" }
}

// 밀도 바 시각화 (최대 30칸)
pure fn density_bar(r: float) -> string {
    let n = to_int(r * 30.0)
    let mut bar = ""
    let mut i = 0
    while i < n {
        bar = bar + "#"
        i = i + 1
    }
    bar
}

fn profile_section(name: string, body: string, original_total: int) -> SectionResult {
    let orig_chars = str_len(body)
    if orig_chars < section_min_chars {
        return SectionResult {
            name: name,
            original_chars: orig_chars,
            compressed_chars: 0,
            r: 0.0,
            grade: "SKIP"
        }
    }

    let prompt = section_compress_prompt + body + "\n---"
    let compressed = llm_call(prompt)
    let comp_chars = str_len(compressed)
    let r = round4(to_float(comp_chars) / to_float(orig_chars))
    let grade = density_grade(r)
    let bar = density_bar(r)

    println("  " + name + " " + to_string(orig_chars) + "->" + to_string(comp_chars) + "  r=" + to_string(r) + "  " + bar + " [" + grade + "]")

    SectionResult {
        name: name,
        original_chars: orig_chars,
        compressed_chars: comp_chars,
        r: r,
        grade: grade
    }
}

// 전체 프로파일 실행 (섹션 리스트를 외부에서 분할하여 전달)
fn profile_text(section_names, section_bodies) -> ProfileReport {
    let count = len(section_names)
    let mut total_orig = 0
    let mut total_comp = 0
    let mut skip_count = 0
    let mut skip_chars = 0

    let mut i = 0
    while i < count {
        let sr = profile_section(section_names[i], section_bodies[i], 0)
        total_orig = total_orig + sr.original_chars
        total_comp = total_comp + sr.compressed_chars
        if sr.grade == "SKIP" || sr.grade == "LOW" {
            skip_count = skip_count + 1
            skip_chars = skip_chars + sr.original_chars
        }
        i = i + 1
    }

    let overall_r = if total_orig > 0 {
        round4(to_float(total_comp) / to_float(total_orig))
    } else { 0.0 }

    println("")
    println("전체: " + to_string(total_orig) + "->" + to_string(total_comp) + " chars (r=" + to_string(overall_r) + ")")
    if skip_count > 0 {
        let skip_pct = round4(to_float(skip_chars) / to_float(total_orig) * 100.0)
        println("삭제 후보 (LOW/SKIP): " + to_string(skip_count) + "섹션, " + to_string(skip_chars) + " chars (" + to_string(skip_pct) + "%)")
    }

    ProfileReport {
        total_original: total_orig,
        total_compressed: total_comp,
        overall_r: overall_r,
        skip_count: skip_count,
        skip_chars: skip_chars,
        section_count: count
    }
}

// ──────────────────────────────────────
// 검증
// ──────────────────────────────────────

assert default_rounds == 5
assert qa_total == 5
assert density_grade(0.40) == "HIGH"
assert density_grade(0.25) == "MED"
assert density_grade(0.15) == "LOW"
assert density_grade(0.05) == "SKIP"
assert round4(0.12345) == 0.1235
assert abs_f(-0.5) == 0.5

println("=== forge verified ===")
println("density_grade(0.40):", density_grade(0.40))
println("density_grade(0.05):", density_grade(0.05))
println("round4(0.12345):", round4(0.12345))
println("abs_f(-0.5):", abs_f(-0.5))

theorem forge_convergence {
    // 반복 자기 압축은 정보론적 하한으로 수렴
    // delta_r → 0 ⟹ 부동점 도달
    check law(6)
}
