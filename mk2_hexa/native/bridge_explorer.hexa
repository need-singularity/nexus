// ─── 헬퍼 함수 ───
fn abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

fn comb(n: int, k: int) -> int {
    if k < 0 { return 0 }
    if k > n { return 0 }
    if k == 0 { return 1 }
    if k == 1 { return n }
    let mut result = 1
    let mut i = 0
    while i < k {
        result = result * (n - i) / (i + 1)
        i = i + 1
    }
    result
}

fn partition_count(n: int) -> int {
    if n < 0 { return 0 }
    if n > 200 { return 0 }
    let mut p = [0] * (n + 1)
    p[0] = 1
    let mut i = 1
    while i <= n {
        let mut j = i
        while j <= n {
            p[j] = p[j] + p[j - i]
            j = j + 1
        }
        i = i + 1
    }
    p[n]
}

fn omega_fn(num: int) -> int {
    let mut c = 0
    let mut t2 = num
    let mut p2 = 2
    while p2 * p2 <= t2 {
        while t2 % p2 == 0 {
            c = c + 1
            t2 = t2 / p2
        }
        p2 = p2 + 1
    }
    if t2 > 1 { c = c + 1 }
    c
}

fn triangular(k: int) -> int {
    k * (k + 1) / 2
}

fn separator() -> string {
    let mut s = ""
    let mut i = 0
    while i < 80 {
        s = s + "="
        i = i + 1
    }
    s
}

