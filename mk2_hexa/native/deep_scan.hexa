    record(9, "6VERTEX", 5, "EXACTLY P1=6 vertex types (ice rule C(tau,2)=6=P1), Yang-Baxter",
           "6-vertex model: P1=6 allowed configurations\n  Ice rule: C(tau,tau/2)=C(4,2)=6=P1\n  Exactly solvable (Bethe ansatz, Lieb 1967)\n  Yang-Baxter: P1=6 R-matrices")
