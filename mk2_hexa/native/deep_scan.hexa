fn run_wave4() {
    separator("WAVE 4 -- New Territory (Nuclear, Music, Cosmology, Neuro, Biology, ...)")

    record(4, "NUCLEAR", 5, "Li-6: Z=N=n/phi, A=P1; C-12=sigma; magic 2,8,20,28=P2; E7 roots=126",
           "Li-6 nucleus: Z=N=3=n/phi, A=6=P1\n  C-12 = sigma(6) nucleons (basis of amu)\n  Magic numbers: 2=phi, 8=n+phi, 20=tau*sopfr, 28=P2\n  126 = |E7 roots|")
    print_record("NUCLEAR", 5, "Li-6=P1, C-12=sigma, magic numbers from n=6",
           "Li-6: A=P1=6, Z=N=n/phi=3\n  C-12 = sigma(6) nucleons\n  Magic: 2,8,20,28 = phi, n+phi, tau*sopfr, P2")

    record(4, "MUSIC", 5, "12-TET = sigma(6) semitones, circle of 5ths=sigma steps, harmonics 1:2:3:4:5:6",
           "12-TET: sigma(6)=12 semitones per octave\n  Circle of fifths: sigma=12 keys\n  Overtone series 1:2:3:4:5:6 = fundamental ratios\n  Perfect fifth = 2:3 = phi:n/phi")
    print_record("MUSIC", 5, "sigma=12 semitones, harmonics 1:2:3:4:5:6",
           "12-TET = sigma(6) = 12 notes\n  Harmonics 1:2:3:4:5:6 define all intervals")

    record(4, "COSMOLOGY", 4, "SM: 6=P1 quarks, 6 leptons, 12=sigma gauge bosons; LCDM 6 params",
           "Standard Model: P1=6 quarks, P1=6 leptons\n  sigma(6)=12 gauge bosons (8 gluons + W+/W-/Z + photon)\n  LCDM cosmology: P1=6 parameters")
    print_record("COSMOLOGY", 4, "SM: P1=6 quarks+leptons, sigma=12 gauge bosons, 6 LCDM params",
           "SM: 6 quarks, 6 leptons, 12 gauge bosons\n  LCDM: 6 parameters")

    record(4, "NEURO", 4, "6 cortical layers, tau=4 lobes, phi=2 hemispheres",
           "Cortex: P1=6 layers (I-VI)\n  Brain: tau(6)=4 lobes\n  Hemispheres: phi(6)=2")
    print_record("NEURO", 4, "P1=6 cortical layers, tau=4 lobes, phi=2 hemispheres",
           "Cortex: 6=P1 layers\n  4=tau lobes, 2=phi hemispheres")

    record(4, "BIOLOGY", 5, "DNA: phi=2 strands, n/phi=3 codon letters, 64=2^P1 codons, 20=tau*sopfr amino acids",
           "DNA: phi(6)=2 strands (double helix)\n  Codon: n/phi=3 nucleotides\n  64 = 2^P1 codons\n  20 = tau*sopfr amino acids\n  Max codon degeneracy = P1 = 6")
    print_record("BIOLOGY", 5, "DNA: phi=2 strands, 3-letter codons, 64=2^P1 codons, 20 amino acids",
           "phi=2 strands, n/phi=3 per codon\n  2^P1 = 64 codons, tau*sopfr = 20 amino acids")

    record(4, "VIRUS", 4, "Icosahedral symmetry: tau*sopfr=20 faces, sigma=12 vertices",
           "Icosahedral viruses: most common symmetry\n  20=tau*sopfr faces, 12=sigma vertices\n  T-number classification uses 6-fold symmetry")
    print_record("VIRUS", 4, "Icosahedral: 20=tau*sopfr faces, 12=sigma vertices",
           "Icosahedral viruses: tau*sopfr faces, sigma vertices")

    record(4, "GAME-THEORY", 4, "Nash n/phi=3 player games rich, Arrow impossible for >=n/phi alternatives",
           "Arrow impossibility: >= n/phi=3 alternatives (PROVEN)\n  Nash equilibrium: always exists (PROVEN)\n  3-player games: richest structure at n/phi")
    print_record("GAME-THEORY", 4, "Arrow impossible >=n/phi=3, Nash exists (PROVEN)",
