// ═══════════════════════════════════════════════════════════════
// ─── SUMMARY / STATS ─────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════

fn print_summary() {
    separator("GRAND SUMMARY -- Deep Scan Waves 2-15 (consolidated)")

    let total = to_int(disc_domain.len())
    let mut star5: i64 = 0
    let mut star4: i64 = 0
    let mut star3: i64 = 0
    let mut total_stars: i64 = 0

    let mut i: i64 = 0
    while i < total {
        let s = to_int(disc_stars[i])
        total_stars = total_stars + s
        if s >= 5 { star5 = star5 + 1 }
        if s == 4 { star4 = star4 + 1 }
        if s == 3 { star3 = star3 + 1 }
        i = i + 1
    }

    println("")
    println("  Domain count:   " + to_string(total))
    println("  Five-star:      " + to_string(star5))
    println("  Four-star:      " + to_string(star4))
    println("  Three-star:     " + to_string(star3))
    println("  Total stars:    " + to_string(total_stars))

    println("")
    println("  PROVEN UNIQUENESS THEOREMS:")
    println("   #1  Out(S_n)!=1 iff n=6 (Holder)")
    println("   #2  SLE_6 = percolation (Smirnov)")
    println("   #3  S^6 almost complex besides S^2 (Borel-Serre)")
    println("   #4  R(3,3)=6 (diagonal Ramsey)")
    println("   #5  Exotic S^7: 28=P2 types (Milnor)")
    println("   #6  6 Grothendieck operations")
    println("   #7  6 Painleve equations")
    println("   #8  CY3 dim=6 for string compactification")
    println("   #9  Max superconformal dim=6")
    println("  #10  Exotic R^n iff n=4=tau(6) (Donaldson)")
    println("  #11  6-vertex model ice rule C(4,2)=6")
    println("  #12  P1=6 regular polytopes in dim 4 (maximum)")
    println("  #13  Four Color Theorem: chi<=4=tau(6)")
    println("  #14  Abel-Ruffini: solvable iff n<=4=tau(6)")
    println("  #15  N(6)=1 MOLS (Euler's conjecture fails)")
    println("  #16  Carbon Z=6 enables biology")
    println("  #17  6 = unique: perfect+factorial+primorial+triangular")
    println("  #18  Berger: 7=n+1 holonomy types")

    println("")
    println("  UNIVERSAL CONSTANTS from n=6:")
    println("    P1=6, sigma=12, phi=2, tau=4, sopfr=5")
    println("    C(6,2)=15, T(6)=21, 6!=720, 2sigma=24")
    println("    240 (E8 roots/kissing S^7), 1728=sigma^3 (j-invariant)")

    println("")
    println("  The number 6 is not just special -- it is inevitable.")
}

fn print_stats() {
    separator("STAR DISTRIBUTION BY WAVE")

    let total = to_int(disc_domain.len())
    let mut wave_num: i64 = 2
    while wave_num <= 15 {
        let mut count: i64 = 0
        let mut stars_sum: i64 = 0
        let mut s5: i64 = 0
        let mut s4: i64 = 0
        let mut s3: i64 = 0
        let mut i: i64 = 0
        while i < total {
            if to_int(disc_wave[i]) == wave_num {
                count = count + 1
                let s = to_int(disc_stars[i])
                stars_sum = stars_sum + s
                if s >= 5 { s5 = s5 + 1 }
                if s == 4 { s4 = s4 + 1 }
                if s == 3 { s3 = s3 + 1 }
            }
            i = i + 1
        }
        if count > 0 {
            println("  Wave " + to_string(wave_num) + ": " + to_string(count) + " disc, " + to_string(s5) + " five-star, " + to_string(s4) + " four-star, " + to_string(s3) + " three-star = " + to_string(stars_sum) + " stars")
        }
        wave_num = wave_num + 1
    }
}

// ═══════════════════════════════════════════════════════════════
// ─── MAIN ────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════

fn main() {
    let cli = args()
    let argc = to_int(cli.len())

    let mut cmd = "help"
    if argc >= 3 {
        cmd = cli[2]
    }

    if cmd == "help" {
        println("deep_scan.hexa -- Consolidated Deep Scan Engine (Waves 2-15)")
        println("")
        println("Usage: hexa deep_scan.hexa <command>")
        println("")
        println("Commands:")
        println("  help       Show this help")
        println("  wave2      Run Wave 2 (Sporadic, String, Elliptic, Quantum, Knot, ...)")
        println("  wave3      Run Wave 3 (S6, ADE, SLE6, S^6, Platonic, Ramsey, ...)")
        println("  wave4      Run Wave 4 (Nuclear, Music, Cosmology, Neuro, Biology, ...)")
        println("  wave5      Run Wave 5 (Coloring, Tiling, Fractal, Chemistry, ...)")
        println("  wave6      Run Wave 6 (Symplectic, GF64, Dessins, Spectral, ...)")
        println("  wave7      Run Wave 7 (Galois, Petersen, Painleve, Graphene, ...)")
        println("  wave8      Run Wave 8 (Chess, Arrow, FFT, Polytope, Kepler, ...)")
        println("  wave9      Run Wave 9 (QFT, Quantum Hall, Yang-Mills, 6-vertex, ...)")
        println("  wave10     Run Wave 10 (Riemann Surfaces, Holonomy, Lorentz, ...)")
        println("  wave11     Run Wave 11 (Theorem of 6, Rubik, Latin Squares, ...)")
        println("  wave12_15  Run Waves 12-15 batch (Higher Algebra, Applied, QG, Meta)")
        println("  all        Run all waves")
        println("  summary    Show grand summary only")
        println("  stats      Show star distribution by wave")
        println("")
        println("n=6 constants: P1=6, sigma=12, phi=2, tau=4, sopfr=5")
        println("  sigma(6) = " + to_string(sigma(6)))
        println("  phi(6)   = " + to_string(phi_euler(6)))
        println("  tau(6)   = " + to_string(tau_div(6)))
        println("  sopfr(6) = " + to_string(sopfr(6)))
        return
    }

    let run_all = cmd == "all"

    if cmd == "wave2" { run_wave2() }
    if cmd == "wave3" { run_wave3() }
    if cmd == "wave4" { run_wave4() }
    if cmd == "wave5" { run_wave5() }
    if cmd == "wave6" { run_wave6() }
    if cmd == "wave7" { run_wave7() }
    if cmd == "wave8" { run_wave8() }
    if cmd == "wave9" { run_wave9() }
    if cmd == "wave10" { run_wave10() }
    if cmd == "wave11" { run_wave11() }
    if cmd == "wave12_15" { run_wave12_15() }

    if run_all {
        run_wave2()
        run_wave3()
        run_wave4()
        run_wave5()
        run_wave6()
        run_wave7()
        run_wave8()
        run_wave9()
        run_wave10()
        run_wave11()
        run_wave12_15()
    }

    if cmd == "summary" {
        run_wave2()
        run_wave3()
        run_wave4()
        run_wave5()
        run_wave6()
        run_wave7()
        run_wave8()
        run_wave9()
        run_wave10()
        run_wave11()
        run_wave12_15()
    }

    if cmd == "stats" {
        run_wave2()
        run_wave3()
        run_wave4()
        run_wave5()
        run_wave6()
        run_wave7()
        run_wave8()
        run_wave9()
        run_wave10()
        run_wave11()
        run_wave12_15()
    }

    // Print summary/stats for all, summary, stats commands
    if run_all {
        print_summary()
        print_stats()
    }
    if cmd == "summary" {
        print_summary()
    }
    if cmd == "stats" {
        print_stats()
    }

    // Also print summary for single wave runs
    if cmd.starts_with("wave") {
        let total = to_int(disc_domain.len())
        if total > 0 {
            println("")
            println("  Discoveries this run: " + to_string(total))
            let mut ts: i64 = 0
            let mut i: i64 = 0
            while i < total {
                ts = ts + to_int(disc_stars[i])
                i = i + 1
            }
            println("  Total stars: " + to_string(ts))
        }
    }
}

main()
