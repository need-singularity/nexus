// mk2_hexa/native/math/sigma_minus1_uniqueness.hexa
// Ported from tecs-l/math/proofs/sigma_minus1_uniqueness.py
// Ported 2026-04-10
//
// σ_{-1}(6) = 2 uniqueness proof.
//
// Claims:
//   1. σ_{-1}(n) = 2 iff n is a perfect number
//   2. For all perfect P: sum(1/d, d>1) = 1
//   3. n=6 is the smallest perfect → fewest EF terms
//   4. 1/2 + 1/3 + 1/6 = 1 is the unique 3-term EF with perfect lcm
//   5. GZ width hierarchy: ln(tau(P)/(tau(P)-1)) strictly decreasing
//
// Note: original used Python fractions.Fraction. Port uses integer lcm
// scaling: to check σ_{-1}(n) ∈ Z, we test whether sigma(n) % n == 0
// and (sigma(n)/n) is the integer value of σ_{-1}(n). Equivalent because
// σ_{-1}(n) = σ(n) / n.

// First 4 even perfect numbers (5th = 33550336 — use analytic tau)
let PERFECTS_SMALL = [6, 28, 496, 8128]
let PERFECT_5 = 33550336
let PERFECT_5_TAU = 26         // 2^12 * 8191 → (12+1)*(1+1)

fn f_abs_f(x: float) -> float {
    if x < 0.0 { 0.0 - x } else { x }
}

// @pure — list all divisors (sorted)
fn divisors_of(n: int) -> [int] {
    let mut out = []
    let mut i = 1
    while i * i <= n {
        if n % i == 0 {
            out = out + [i]
            if i != n / i {
                out = out + [n / i]
            }
        }
        i = i + 1
    }
    out
}

// @pure — integer check: is σ_{-1}(n) ∈ Z? (σ(n) % n == 0)
fn sigma_minus1_int(n: int) -> int {
    let s = sigma(n)
    if s % n == 0 { return s / n }
    0    // not integer → return 0 sentinel
}

// @pure — check if n is perfect (σ(n) = 2n)
fn is_perfect(n: int) -> bool {
    sigma(n) == 2 * n
}

// @pure — integer lcm
fn lcm_int(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    while y != 0 {
        let r = x % y
        x = y
        y = r
    }
    a / x * b
}

println("======================================================================")
println("σ_{-1}(6) = 2 UNIQUENESS PROOF")
println("======================================================================")

// ─── PART 1: Search n in [1, 10000] with σ_{-1}(n) ∈ Z ───
println("")
println("======================================================================")
println("PART 1: Search n ≤ 10000 with σ_{-1}(n) ∈ Z")
println("======================================================================")
println("")
println("  (using σ_{-1}(n) = σ(n)/n, so integrality ⇔ n | σ(n))")
println("")
println("         n        σ_{-1}(n)       status")
println("  -----------------------------------------")

let mut integer_count = 0
let mut perfect_count = 0
let mut multi_count = 0
let mut n = 1
while n <= 10000 {
    let s = sigma(n)
    if s % n == 0 {
        let v = s / n
        integer_count = integer_count + 1
        if n == 1 {
            println("  " + to_string(n) + "         " + to_string(v) + "         trivial")
        } else {
            if v == 2 {
                perfect_count = perfect_count + 1
                println("  " + to_string(n) + "         " + to_string(v) + "         PERFECT")
            } else {
                if v > 2 {
                    multi_count = multi_count + 1
                    println("  " + to_string(n) + "         " + to_string(v) + "         multiply perfect")
                }
            }
        }
    }
    n = n + 1
}
println("")
println("  Total integer σ_{-1}: " + to_string(integer_count))
println("  Perfect (σ_{-1}=2):  " + to_string(perfect_count))
println("  Multiply perfect:    " + to_string(multi_count))

// ─── PART 2: Verify sum(1/d, d>1) = 1 for each known perfect ───
println("")
println("======================================================================")
println("PART 2: Verify sum(1/d for d|P, d>1) = 1 for perfect P")
println("======================================================================")
println("")
println("  THEOREM: σ_{-1}(P) = 2 ⇒ sum(1/d for d>1) = 2 - 1/1 = 1  QED")
println("")

let mut pi = 0
while pi < len(PERFECTS_SMALL) {
    let P = PERFECTS_SMALL[pi]
    let divs = divisors_of(P)
    // Verify sigma == 2P
    let ok_perfect = if sigma(P) == 2 * P { "YES" } else { "NO" }
    println("  P = " + to_string(P) + "  perfect? " + ok_perfect + "  tau=" + to_string(tau(P)) + "  terms(d>1) = " + to_string(tau(P) - 1))
    pi = pi + 1
}
println("  P = " + to_string(PERFECT_5) + "  (analytic: tau = " + to_string(PERFECT_5_TAU) + ")")

// ─── PART 3: Egyptian fraction term counts & GZ width ───
println("")
println("======================================================================")
println("PART 3: EF term counts and GZ width = ln(tau/(tau-1))")
println("======================================================================")
println("")
println("           P      tau    terms    GZ_width    vs n=6")
println("  ---------------------------------------------------")

let gz6 = log(4.0 / 3.0)
let mut rank = 1
let mut pj = 0
while pj < len(PERFECTS_SMALL) {
    let P = PERFECTS_SMALL[pj]
    let t = tau(P)
    let terms = t - 1
    let gz_w = log(to_float(t) / to_float(t - 1))
    let ratio = gz_w / gz6
    println("  " + to_string(rank) + "  " + to_string(P) + "  " + to_string(t) + "  " + to_string(terms) + "  " + to_string(gz_w) + "  " + to_string(ratio) + "x")
    rank = rank + 1
    pj = pj + 1
}

// 5th perfect — analytic
let gz_5 = log(to_float(PERFECT_5_TAU) / to_float(PERFECT_5_TAU - 1))
println("  " + to_string(rank) + "  " + to_string(PERFECT_5) + "  " + to_string(PERFECT_5_TAU) + "  " + to_string(PERFECT_5_TAU - 1) + "  " + to_string(gz_5) + "  " + to_string(gz_5 / gz6) + "x")

println("")
println("  n=6 GZ width = ln(4/3) = " + to_string(gz6) + "  ← WIDEST")

// Verify strictly decreasing
let mut prev_w = log(4.0 / 3.0)
let mut dec_ok = true
let mut pk = 1
while pk < len(PERFECTS_SMALL) {
    let P = PERFECTS_SMALL[pk]
    let t = tau(P)
    let w = log(to_float(t) / to_float(t - 1))
    if w >= prev_w { dec_ok = false }
    prev_w = w
    pk = pk + 1
}
if gz_5 >= prev_w { dec_ok = false }
if dec_ok {
    println("  GZ widths strictly decreasing: true")
} else {
    println("  GZ widths strictly decreasing: FALSE — anomaly!")
}

// ─── PART 4: All 3-term EF 1/a + 1/b + 1/c = 1 ───
println("")
println("======================================================================")
println("PART 4: All 3-term Egyptian fractions 1/a + 1/b + 1/c = 1")
println("======================================================================")
println("")
println("  a  b  c  lcm  perfect_lcm?")

// 1/a + 1/b + 1/c = 1, 1 < a ≤ b ≤ c
// smallest term 1/a ≥ 1/3, so a ∈ {2, 3}
let mut perfect_lcm_count = 0
let mut pa = 2
while pa <= 3 {
    let mut pb = pa
    while pb <= 2000 {
        // 1/c = 1 - 1/a - 1/b;  scale: (ab - b - a) / (ab) = 1/c
        // so c = ab / (ab - a - b), if ab - a - b > 0 and divides ab
        let num = pa * pb
        let den = pa * pb - pa - pb
        if den > 0 && num % den == 0 {
            let c = num / den
            if c >= pb {
                let L1 = lcm_int(pa, pb)
                let L = lcm_int(L1, c)
                // is L in {6, 28, 496, 8128, 33550336}?
                let mut is_perf = false
                if L == 6 { is_perf = true }
                if L == 28 { is_perf = true }
                if L == 496 { is_perf = true }
                if L == 8128 { is_perf = true }
                if L == 33550336 { is_perf = true }
                if is_perf { perfect_lcm_count = perfect_lcm_count + 1 }
                let tag = if is_perf { "  *** PERFECT ***" } else { "" }
                println("  " + to_string(pa) + "  " + to_string(pb) + "  " + to_string(c) + "  " + to_string(L) + "  " + tag)
            }
        }
        pb = pb + 1
    }
    pa = pa + 1
}

println("")
println("  Solutions with perfect lcm: " + to_string(perfect_lcm_count))
if perfect_lcm_count == 1 {
    println("  CONFIRMED: 1/2 + 1/3 + 1/6 = 1 is UNIQUE 3-term EF with perfect lcm.")
} else {
    println("  Found " + to_string(perfect_lcm_count) + " solutions — not unique!")
}

// ─── PART 6: Direct verification of σ_{-1}(6) = 2 ───
println("")
println("======================================================================")
println("PART 6: Direct computation σ_{-1}(6) = 2")
println("======================================================================")

let s6 = sigma(6)
println("")
println("  divisors of 6: 1, 2, 3, 6")
println("  σ(6) = " + to_string(s6))
println("  σ_{-1}(6) = σ(6) / 6 = " + to_string(s6 / 6))
let is_2 = if s6 == 12 { "true" } else { "false" }
println("  σ_{-1}(6) == 2 ? " + is_2)
println("")
println("  Master identity: 1/2 + 1/3 + 1/6 = 1")
println("  (scale by 6): 3 + 2 + 1 = 6  ✓")

// ─── CONCLUSION ───
println("")
println("======================================================================")
println("CONCLUSION — 5 claims verified")
println("======================================================================")
println("")
println("  1. σ_{-1}(n) = 2 iff n is perfect")
println("     Found in [1, 10000]: 6, 28, 496, 8128")
println("     Plus 33550336 (analytically)")
println("")
println("  2. For perfect P: sum(1/d, d>1) = 1   [QED: σ_{-1}(P)=2, subtract 1]")
println("")
println("  3. n=6 = smallest perfect → fewest EF terms (tau(6)-1 = 3)")
println("")
println("  4. 1/2 + 1/3 + 1/6 = 1 is the UNIQUE 3-term EF with perfect lcm")
println("")
println("  5. n=6 has WIDEST GZ = ln(4/3) = " + to_string(gz6))
println("     (all larger perfects have narrower GZ)")
println("")
println("  Bonus: (1/2, 1/3, 1/6) = (boundary, convergence, curiosity)")
println("         in TECS-L framework — complete cycle.")
println("")
println("  Golden Zone ANCHOR: n=6 is uniquely optimal.")

