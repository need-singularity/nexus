// mk2_hexa/native/multi_agent.hexa — 멀티 에이전트 협업 프로토콜
// collaboration: 병렬 발견 태스크 병합 + 중복 제거
// consensus: 에이전트 간 합의 수준 판정
// conflict: 충돌 감지 + 자동 해소
// CLI: hexa multi_agent.hexa dispatch|collect|merge

// ──────────────────────────────────────
// AgentReport (간이 구조)
// ──────────────────────────────────────

struct MAReport {
    agent_id: string,
    mode: string,             // "explore", "deepen", "verify", "redteam"
    cycles_completed: int,
    discoveries: str,
    time_elapsed_ms: int,
    domains_covered: str
}

fn make_report(id: string, mode: string, cycles: int, discoveries, time_ms: int, domains) -> MAReport {
    MAReport {
        agent_id: id,
        mode: mode,
        cycles_completed: cycles,
        discoveries: discoveries,
        time_elapsed_ms: time_ms,
        domains_covered: domains
    }
}

// ──────────────────────────────────────
// 유틸리티
// ──────────────────────────────────────

fn contains_str(arr, s: string) -> bool {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == s { return true }
        i = i + 1
    }
    false
}

fn normalize_discovery(d: string) -> string {
    lowercase(trim(d))
}

fn truncate(s: string, max_len: int) -> string {
    if len(s) <= max_len { s }
    else { substring(s, 0, max_len) + "..." }
}

// 단어 분할 (공백 기준)
fn split_words(s: string) {
    split(s, " ")
}

// 두 단어 목록의 교집합 (3글자 이상만)
fn word_overlap(a: string, b: string) {
    let words_a = split_words(lowercase(a))
    let words_b = split_words(lowercase(b))
    let mut overlap = []
    let mut i = 0
    while i < len(words_a) {
        let w = trim(words_a[i])
        if len(w) > 2 && contains_str(words_b, w) && !contains_str(overlap, w) {
            let overlap = overlap.push(w)
        }
        i = i + 1
    }
    overlap
}

// ──────────────────────────────────────
// MultiAgentResult
// ──────────────────────────────────────

struct MultiAgentResult {
    merged_discoveries: str,
    consensus_discoveries: str,
    conflicts: str,
    synergies: str,
    total_cycles: int,
    total_time_ms: int
}

// ──────────────────────────────────────
// collaboration: 협업 분석
// ──────────────────────────────────────

fn collaborate(names, reports) -> MultiAgentResult {
    let n = len(reports)

    // 모든 발견 수집 + 중복 제거
    let mut all_discoveries = []
    // discovery -> agent count 추적 (간이: discovery_names, discovery_counts)
    let mut disc_names = []
    let mut disc_counts = []

    let mut ri = 0
    while ri < n {
        let r = reports[ri]
        let agent_name = names[ri]
        let mut di = 0
        while di < len(r.discoveries) {
            let norm = normalize_discovery(r.discoveries[di])
            // 이미 있으면 카운트 증가
            let mut found_idx = -1
            let mut fi = 0
            while fi < len(disc_names) {
                if disc_names[fi] == norm { found_idx = fi }
                fi = fi + 1
            }
            if found_idx >= 0 {
                disc_counts[found_idx] = disc_counts[found_idx] + 1
            } else {
                let disc_names = disc_names.push(norm)
                let disc_counts = disc_counts.push(1)
                let all_discoveries = all_discoveries.push(norm)
            }
            di = di + 1
        }
        ri = ri + 1
    }

    // 합의: 2+ 에이전트가 발견
    let mut consensus = []
    let mut ci = 0
    while ci < len(disc_names) {
        if disc_counts[ci] >= 2 {
            let consensus = consensus.push(disc_names[ci])
        }
        ci = ci + 1
    }

    // 충돌 감지: redteam vs 다른 모드
    let conflicts = detect_conflicts(names, reports)

    // 시너지: 교차 도메인 패턴
    let synergies = detect_synergies(names, reports)

    // 합산
    let mut total_cycles = 0
    let mut total_time = 0
    let mut ti = 0
    while ti < n {
        total_cycles = total_cycles + reports[ti].cycles_completed
        total_time = total_time + reports[ti].time_elapsed_ms
        ti = ti + 1
    }

    MultiAgentResult {
        merged_discoveries: all_discoveries,
        consensus_discoveries: consensus,
        conflicts: conflicts,
        synergies: synergies,
        total_cycles: total_cycles,
        total_time_ms: total_time
    }
}

// ──────────────────────────────────────
// conflict: 충돌 감지
// ──────────────────────────────────────

fn detect_conflicts(names, reports) {
    let n = len(reports)
    let mut conflicts = []

    // redteam 발견 vs 다른 발견
    let mut rt_discs = []
    let mut other_discs = []

    let mut i = 0
    while i < n {
        let r = reports[i]
        let mut di = 0
        while di < len(r.discoveries) {
            if r.mode == "redteam" {
                let rt_discs = rt_discs.push(r.discoveries[di])
            } else {
                let other_discs = other_discs.push(r.discoveries[di])
            }
            di = di + 1
        }
        i = i + 1
    }

    // 단어 겹침 3+ 이면 충돌 판정
    let mut ri = 0
    while ri < len(rt_discs) {
        let mut oi = 0
        while oi < len(other_discs) {
            let overlap = word_overlap(rt_discs[ri], other_discs[oi])
            if len(overlap) >= 3 {
                let msg = "Conflict: redteam '" + truncate(rt_discs[ri], 60) + "' vs '" + truncate(other_discs[oi], 60) + "'"
                let conflicts = conflicts.push(msg)
            }
            oi = oi + 1
        }
        ri = ri + 1
    }

    conflicts
}

// ──────────────────────────────────────
// conflict: 자동 해소
// ──────────────────────────────────────

comptime const resolve_unresolved = 0
comptime const resolve_accept_a = 1
comptime const resolve_accept_b = 2
comptime const resolve_compatible = 3

struct Conflict {
    agent_a: string,
    agent_b: string,
    discovery_a: string,
    discovery_b: string,
    overlap_words: str,
    resolution: int
}

fn mode_priority(mode: string) -> int {
    match mode {
        "redteam" -> 3,
        "verify"  -> 2,
        "deepen"  -> 1,
        _         -> 0
    }
}

fn detect_conflicts_detailed(names, reports) {
    let n = len(reports)
    let mut conflicts = []

    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            // 다른 모드만 충돌 판정
            if reports[i].mode != reports[j].mode {
                let mut di = 0
                while di < len(reports[i].discoveries) {
                    let mut dj = 0
                    while dj < len(reports[j].discoveries) {
                        let overlap = word_overlap(reports[i].discoveries[di], reports[j].discoveries[dj])
                        if len(overlap) >= 3 {
                            let conflicts = conflicts.push(Conflict {
                                agent_a: names[i],
                                agent_b: names[j],
                                discovery_a: reports[i].discoveries[di],
                                discovery_b: reports[j].discoveries[dj],
                                overlap_words: overlap,
                                resolution: resolve_unresolved
                            })
                        }
                        dj = dj + 1
                    }
                    di = di + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    conflicts
}

fn auto_resolve(conflicts, names, reports) {
    let mut resolved = []
    let mut ci = 0
    while ci < len(conflicts) {
        let mut c = conflicts[ci]

        // 에이전트 리포트 찾기
        let mut ra_mode = ""
        let mut rb_mode = ""
        let mut ra_cycles = 0
        let mut rb_cycles = 0
        let mut ri = 0
        while ri < len(names) {
            if names[ri] == c.agent_a {
                ra_mode = reports[ri].mode
                ra_cycles = reports[ri].cycles_completed
            }
            if names[ri] == c.agent_b {
                rb_mode = reports[ri].mode
                rb_cycles = reports[ri].cycles_completed
            }
            ri = ri + 1
        }

        let a_pri = mode_priority(ra_mode)
        let b_pri = mode_priority(rb_mode)

        if a_pri > b_pri {
            c.resolution = resolve_accept_a
        } else if b_pri > a_pri {
            c.resolution = resolve_accept_b
        } else if ra_cycles > rb_cycles * 2 {
            c.resolution = resolve_accept_a
        } else if rb_cycles > ra_cycles * 2 {
            c.resolution = resolve_accept_b
        }
        // else UNRESOLVED

        let resolved = resolved.push(c)
        ci = ci + 1
    }
    resolved
}

fn resolution_name(r: int) -> string {
    match r {
        0 -> "unresolved",
        1 -> "accept_a",
        2 -> "accept_b",
        3 -> "compatible",
        _ -> "unknown"
    }
}

// ──────────────────────────────────────
// consensus: 합의 수준 판정
// ──────────────────────────────────────

comptime const consensus_single = 0
comptime const consensus_pair = 1
comptime const consensus_strong = 2
comptime const consensus_unanimous = 3

fn consensus_name(c: int) -> string {
    match c {
        0 -> "single",
        1 -> "pair",
        2 -> "strong",
        3 -> "unanimous",
        _ -> "unknown"
    }
}

struct ConsensusEntry {
    discovery: string,
    level: int,
    agent_count: int,
    total_agents: int,
    agents: str
}

fn compute_consensus(names, reports) {
    let total_agents = len(reports)

    // discovery -> agents 매핑
    let mut disc_keys = []
    let mut disc_agents_list = []  // [string] 배열의 배열 대신 "a,b,c" 문자열

    let mut ri = 0
    while ri < len(reports) {
        let agent_name = names[ri]
        let mut di = 0
        while di < len(reports[ri].discoveries) {
            let norm = normalize_discovery(reports[ri].discoveries[di])
            let mut found_idx = -1
            let mut fi = 0
            while fi < len(disc_keys) {
                if disc_keys[fi] == norm { found_idx = fi }
                fi = fi + 1
            }
            if found_idx >= 0 {
                // 에이전트 추가 (중복 방지)
                let existing = disc_agents_list[found_idx]
                if !contains_str(split(existing, ","), agent_name) {
                    disc_agents_list[found_idx] = existing + "," + agent_name
                }
            } else {
                let disc_keys = disc_keys.push(norm)
                let disc_agents_list = disc_agents_list.push(agent_name)
            }
            di = di + 1
        }
        ri = ri + 1
    }

    // ConsensusEntry 생성
    let mut entries = []
    let mut ei = 0
    while ei < len(disc_keys) {
        let agents_str = disc_agents_list[ei]
        let agents = split(agents_str, ",")
        let agent_count = len(agents)

        let level = if agent_count >= total_agents && total_agents > 1 {
            consensus_unanimous
        } else if agent_count >= 3 {
            consensus_strong
        } else if agent_count >= 2 {
            consensus_pair
        } else {
            consensus_single
        }

        let entries = entries.push(ConsensusEntry {
            discovery: disc_keys[ei],
            level: level,
            agent_count: agent_count,
            total_agents: total_agents,
            agents: agents
        })
        ei = ei + 1
    }

    // 정렬: level 오름차순 (unanimous=3 먼저), agent_count 내림차순
    // 간이 삽입 정렬
    let n = len(entries)
    let mut i = 1
    while i < n {
        let key = entries[i]
        let key_ord = key.level * 1000 + key.agent_count
        let mut j = i - 1
        while j >= 0 {
            let j_ord = entries[j].level * 1000 + entries[j].agent_count
            if j_ord < key_ord {
                entries[j + 1] = entries[j]
                j = j - 1
            } else {
                j = -1  // break
            }
        }
        entries[j + 1] = key
        i = i + 1
    }

    entries
}

fn filter_by_min_agents(entries, min_count: int) {
    let mut result = []
    let mut i = 0
    while i < len(entries) {
        if entries[i].agent_count >= min_count {
            let result = result.push(entries[i])
        }
        i = i + 1
    }
    result
}

// ──────────────────────────────────────
// synergy: 교차 도메인 시너지 감지
// ──────────────────────────────────────

fn detect_synergies(names, reports) {
    let n = len(reports)
    let mut synergies = []

    // 발견이 있는 에이전트만 추출
    let mut active_idx = []
    let mut ai = 0
    while ai < n {
        if len(reports[ai].discoveries) > 0 {
            let active_idx = active_idx.push(ai)
        }
        ai = ai + 1
    }

    // 쌍별 교차 도메인 검사
    let mut i = 0
    while i < len(active_idx) {
        let mut j = i + 1
        while j < len(active_idx) {
            let ai2 = active_idx[i]
            let bi2 = active_idx[j]
            let a_domains = reports[ai2].domains_covered
            let b_domains = reports[bi2].domains_covered

            // A 고유 도메인
            let mut a_unique = []
            let mut adi = 0
            while adi < len(a_domains) {
                if !contains_str(b_domains, a_domains[adi]) {
                    let a_unique = a_unique.push(a_domains[adi])
                }
                adi = adi + 1
            }

            // B 고유 도메인
            let mut b_unique = []
            let mut bdi = 0
            while bdi < len(b_domains) {
                if !contains_str(a_domains, b_domains[bdi]) {
                    let b_unique = b_unique.push(b_domains[bdi])
                }
                bdi = bdi + 1
            }

            // 공유 도메인
            let mut shared = []
            let mut sdi = 0
            while sdi < len(a_domains) {
                if contains_str(b_domains, a_domains[sdi]) {
                    let shared = shared.push(a_domains[sdi])
                }
                sdi = sdi + 1
            }

            if len(a_unique) > 0 && len(b_unique) > 0 {
                let synergies = synergies.push("Cross-domain synergy: " + names[ai2] + " (" + to_string(a_unique) + ") x " + names[bi2] + " (" + to_string(b_unique) + ")")
            }
            if len(shared) > 0 {
                let synergies = synergies.push("Shared domain convergence: " + names[ai2] + " + " + names[bi2] + " on " + to_string(shared))
            }

            j = j + 1
        }
        i = i + 1
    }

    synergies
}

// ──────────────────────────────────────
// CLI 엔트리포인트
// ──────────────────────────────────────

fn print_result(result: MultiAgentResult) {
    println("=== Multi-Agent Result ===")
    println("  Total cycles: " + to_string(result.total_cycles))
    println("  Total time: " + to_string(result.total_time_ms) + "ms")
    println("  Merged discoveries: " + to_string(len(result.merged_discoveries)))
    let mut mi = 0
    while mi < len(result.merged_discoveries) {
        println("    - " + result.merged_discoveries[mi])
        mi = mi + 1
    }
    println("  Consensus discoveries: " + to_string(len(result.consensus_discoveries)))
    let mut ci = 0
    while ci < len(result.consensus_discoveries) {
        println("    * " + result.consensus_discoveries[ci])
        ci = ci + 1
    }
    println("  Conflicts: " + to_string(len(result.conflicts)))
    let mut fi = 0
    while fi < len(result.conflicts) {
        println("    ! " + result.conflicts[fi])
        fi = fi + 1
    }
    println("  Synergies: " + to_string(len(result.synergies)))
    let mut si = 0
    while si < len(result.synergies) {
        println("    + " + result.synergies[si])
        si = si + 1
    }
}

fn demo_dispatch() {
    println("=== Dispatch: Multi-Agent Tasks ===")
    let names = ["explorer", "deepener", "redteam-1"]
    let reports = [ make_report("explorer", "explore", 6, ["pattern alpha found", "constant beta detected"], 500, ["physics", "topology"]), make_report("deepener", "deepen", 6, ["pattern alpha found", "deep structure gamma"], 700, ["physics"]), make_report("redteam-1", "redteam", 6, ["pattern alpha found in physics domain disproved"], 300, ["physics"]) ]

    let result = collaborate(names, reports)
    print_result(result)

    // 상세 충돌 분석
    let conflicts = detect_conflicts_detailed(names, reports)
    let resolved = auto_resolve(conflicts, names, reports)
    println("\n  Detailed conflicts: " + to_string(len(resolved)))
    let mut i = 0
    while i < len(resolved) {
        let c = resolved[i]
        println("    " + c.agent_a + " vs " + c.agent_b + " -> " + resolution_name(c.resolution))
        i = i + 1
    }

    // 합의 분석
    let consensus = compute_consensus(names, reports)
    println("\n  Consensus entries: " + to_string(len(consensus)))
    let mut ci = 0
    while ci < len(consensus) {
        let e = consensus[ci]
        println("    [" + consensus_name(e.level) + "] " + e.discovery + " (" + to_string(e.agent_count) + "/" + to_string(e.total_agents) + " agents)")
        ci = ci + 1
    }
}

fn main() {
    let argv = args()
    let cmd = if len(argv) > 1 { argv[1] } else { "dispatch" }

    match cmd {
        "dispatch" -> {
            demo_dispatch()
        },
        "collect" -> {
            println("=== Collect: gathering agent reports... ===")
            // 파일 기반 수집
            let path = if len(argv) > 2 { argv[2] } else { "shared/agent_reports.txt" }
            try {
                let data = read_file(path)
                println("  Read " + to_string(len(data)) + " bytes from " + path)
                println("  (Parse and collaborate with full implementation)")
            } catch e {
                println("  No report file at " + path)
                println("  Run agents first, then collect.")
            }
        },
        "merge" -> {
            println("=== Merge: combining results ===")
            demo_dispatch()
            println("\n  Merge complete.")
        },
        _ -> {
            println("Usage: hexa multi_agent.hexa dispatch|collect|merge")
        }
    }
}

// ──────────────────────────────────────
// 검증
// ──────────────────────────────────────

// normalize
assert normalize_discovery("  Hello World  ") == "hello world"

// word_overlap
let ov1 = word_overlap("alpha beta gamma delta", "gamma delta epsilon zeta")
assert contains_str(ov1, "gamma")
assert contains_str(ov1, "delta")

// mode_priority
assert mode_priority("redteam") > mode_priority("verify")
assert mode_priority("verify") > mode_priority("deepen")
assert mode_priority("deepen") > mode_priority("explore")

// consensus_name
assert consensus_name(consensus_single) == "single"
assert consensus_name(consensus_unanimous) == "unanimous"

// resolution_name
assert resolution_name(resolve_unresolved) == "unresolved"
assert resolution_name(resolve_accept_a) == "accept_a"

// collaborate: empty
let empty_result = collaborate([], [])
assert len(empty_result.merged_discoveries) == 0
assert len(empty_result.consensus_discoveries) == 0
assert empty_result.total_cycles == 0

// collaborate: merge + consensus
let names_2 = ["explorer", "deepener"]
let reports_2 = [ make_report("explorer", "explore", 6, ["discovery A", "discovery B"], 100, ["physics"]), make_report("deepener", "deepen", 6, ["discovery A", "discovery C"], 100, ["physics"]) ]
let result_2 = collaborate(names_2, reports_2)
assert len(result_2.merged_discoveries) == 3  // a, b, c
assert len(result_2.consensus_discoveries) == 1  // a (found by both)
assert result_2.total_cycles == 12

// collaborate: cross-domain synergy
let names_3 = ["agent-a", "agent-b"]
let reports_3 = [ make_report("agent-a", "explore", 6, ["found X"], 100, ["physics"]), make_report("agent-b", "explore", 6, ["found Y"], 100, ["biology"]) ]
let result_3 = collaborate(names_3, reports_3)
assert len(result_3.synergies) > 0

// no conflicts without redteam
let names_4 = ["a", "b"]
let reports_4 = [ make_report("a", "explore", 6, ["disc 1"], 100, ["physics"]), make_report("b", "deepen", 6, ["disc 2"], 100, ["physics"]) ]
let result_4 = collaborate(names_4, reports_4)
assert len(result_4.conflicts) == 0

// no conflicts same mode (detailed)
let names_5 = ["a", "b"]
let reports_5 = [ make_report("a", "explore", 6, ["found pattern alpha beta gamma"], 100, ["test"]), make_report("b", "explore", 6, ["found pattern alpha beta gamma"], 100, ["test"]) ]
let conflicts_5 = detect_conflicts_detailed(names_5, reports_5)
assert len(conflicts_5) == 0  // same mode = no conflict

// consensus: single agent
let names_6 = ["a"]
let reports_6 = [make_report("a", "explore", 1, ["disc 1", "disc 2"], 10, ["test"])]
let consensus_6 = compute_consensus(names_6, reports_6)
assert len(consensus_6) == 2
assert consensus_6[0].level == consensus_single

// consensus: pair (2/2 = unanimous)
let names_7 = ["a", "b"]
let reports_7 = [ make_report("a", "explore", 1, ["shared discovery"], 10, ["test"]), make_report("b", "explore", 1, ["shared discovery", "unique"], 10, ["test"]) ]
let consensus_7 = compute_consensus(names_7, reports_7)
let mut found_shared = false
let mut ci7 = 0
while ci7 < len(consensus_7) {
    if consensus_7[ci7].discovery == "shared discovery" {
        assert consensus_7[ci7].level == consensus_unanimous  // 2/2
        assert consensus_7[ci7].agent_count == 2
        found_shared = true
    }
    ci7 = ci7 + 1
}
assert found_shared

// filter_by_min_agents
let filtered = filter_by_min_agents(consensus_7, 2)
assert len(filtered) == 1
assert filtered[0].discovery == "shared discovery"

println("=== multi_agent verified ===")
