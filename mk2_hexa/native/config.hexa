// mk2_hexa/native/config.hexa — 설정 파일 관리 (Rust src/config.rs 포팅)
// ~/.nexus/config.toml 읽기/쓰기 (간이 TOML 파서)
// 실행: hexa config.hexa get <key>
//       hexa config.hexa set <key> <value>
//       hexa config.hexa list
//       hexa config.hexa init
//       hexa config.hexa section <name>

// ─── 설정 ───
comptime const home_env = "HOME"
comptime const config_subpath = "/.nexus/config.toml"

// ─── 기본값 ───
comptime const default_loop_domain = "number_theory"
comptime const default_loop_cycles = 1
comptime const default_loop_max_ouroboros = 6
comptime const default_loop_max_meta = 6
comptime const default_loop_forge_after = 3

comptime const default_daemon_interval = 30
comptime const default_blowup_domain = "number_theory"
comptime const default_blowup_depth = 6
comptime const default_blowup_max_corollaries = 216
comptime const default_blowup_min_confidence = 0.15

comptime const default_evolution_serendipity = 0.3
comptime const default_evolution_min_verify = 0.5
comptime const default_evolution_max_mutations = 20

comptime const default_forge_max_candidates = 20
comptime const default_forge_min_confidence = 0.2
comptime const default_forge_similarity = 0.8

comptime const default_log_max_bytes = 1048576
comptime const default_log_max_files = 5

// ─── config 파일 경로 결정 ───
fn config_path() -> string {
    // env HOME 읽기 시도 — hexa에서는 간이 방법
    // 후보: read_file로 알려진 경로 탐색
    let home_candidates = exec("printenv HOME")
    home_candidates + config_subpath
}

// ─── 간이 TOML 파서 ───
// 지원, key = value, key = "string", # 주석
// 중첩 미지원 (flat key 방식: section.key)

struct ConfigEntry {
    section: string,
    key: string,
    value: string
}

fn parse_toml(content: string) -> string {
    // 전체 파싱 결과를 "section.key=value\n" 형태로 반환
    let lines = content.split("\n")
    let mut current_section = ""
    let mut result = ""
    let mut i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        // 주석/빈줄 스킵
        if line == "" {
            i = i + 1
            continue
        }
        if line.slice(0, 1) == "#" {
            i = i + 1
            continue
        }
        // 섹션 헤더
        if line.slice(0, 1) == "[" {
            let end = line.index_of("]")
            if end > 0 {
                current_section = line.slice(1, end).trim()
            }
            i = i + 1
            continue
        }
        // key = value
        let eq = line.index_of("=")
        if eq > 0 {
            let key = line.slice(0, eq).trim()
            let mut val = line.slice(eq + 1, len(line)).trim()
            // 인라인 주석 제거
            let hash = val.index_of("#")
            if hash > 0 {
                val = val.slice(0, hash).trim()
            }
            // 따옴표 제거
            if len(val) >= 2 {
                if val.slice(0, 1) == "\"" {
                    let last = val.slice(len(val) - 1, len(val))
                    if last == "\"" {
                        val = val.slice(1, len(val) - 1)
                    }
                }
            }
            let full_key = if current_section != "" { current_section + "." + key } else { key }
            result = result + full_key + "=" + val + "\n"
        }
        i = i + 1
    }
    result
}

// ─── 키-값 조회 ───
fn get_value(parsed: string, key: string) -> string {
    let needle = key + "="
    let lines = parsed.split("\n")
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        if line.index_of(needle) == 0 {
            return line.slice(len(needle), len(line))
        }
        i = i + 1
    }
    ""
}

// ─── config 전체 읽기 ───
fn load_config() -> string {
    let path = config_path()
    let content = read_file(path)
    if content == "" {
        return ""
    }
    parse_toml(content)
}

// ─── config에서 값 가져오기 (기본값 포함) ───
fn config_get(key: string) -> string {
    let parsed = load_config()
    let val = get_value(parsed, key)
    if val != "" { return val }

    // 기본값 반환
    match key {
        "loop.domain" -> default_loop_domain,
        "loop.cycles" -> to_string(default_loop_cycles),
        "loop.max_ouroboros_cycles" -> to_string(default_loop_max_ouroboros),
        "loop.max_meta_cycles" -> to_string(default_loop_max_meta),
        "loop.forge_after_n_cycles" -> to_string(default_loop_forge_after),
        "daemon.interval_min" -> to_string(default_daemon_interval),
        "blowup.domain" -> default_blowup_domain,
        "blowup.max_depth" -> to_string(default_blowup_depth),
        "blowup.max_corollaries" -> to_string(default_blowup_max_corollaries),
        "blowup.min_confidence" -> to_string(default_blowup_min_confidence),
        "evolution.serendipity_ratio" -> to_string(default_evolution_serendipity),
        "evolution.min_verification_score" -> to_string(default_evolution_min_verify),
        "evolution.max_mutations_per_cycle" -> to_string(default_evolution_max_mutations),
        "forge.max_candidates" -> to_string(default_forge_max_candidates),
        "forge.min_confidence" -> to_string(default_forge_min_confidence),
        "forge.similarity_threshold" -> to_string(default_forge_similarity),
        "log_rotation.max_bytes" -> to_string(default_log_max_bytes),
        "log_rotation.max_files" -> to_string(default_log_max_files),
        _ -> ""
    }
}

// ─── config에 값 쓰기 ───
fn config_set(key: string, value: string) {
    let path = config_path()
    let content = read_file(path)

    // key를 section.name 으로 분리
    let dot = key.index_of(".")
    let mut section = ""
    let mut name = key
    if dot > 0 {
        section = key.slice(0, dot)
        name = key.slice(dot + 1, len(key))
    }

    let section_header = "[" + section + "]"
    let entry = name + " = " + value

    if content == "" {
        // 새 파일
        let new_content = if section != "" { section_header + "\n" + entry + "\n" } else { entry + "\n" }
        write_file(path, new_content)
        print("set " + key + " = " + value + " (new file)")
        return
    }

    let lines = content.split("\n")
    let mut result = []
    let mut in_section = false
    let mut replaced = false
    let mut section_exists = false
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        let trimmed = line.trim()

        // 섹션 헤더 체크
        if len(trimmed) > 0 {
            if trimmed.slice(0, 1) == "[" {
                if in_section {
                    if !replaced {
                        // 섹션 끝에 도달, 키 없었으므로 추가
                        result = result.push(entry)
                        replaced = true
                    }
                }
                if trimmed == section_header {
                    in_section = true
                    section_exists = true
                } else {
                    in_section = false
                }
            }
        }

        // 현재 섹션 내에서 키 찾기
        if in_section {
            if trimmed.slice(0, 1) != "#" {
                if trimmed.slice(0, 1) != "[" {
                    let eq = trimmed.index_of("=")
                    if eq > 0 {
                        let k = trimmed.slice(0, eq).trim()
                        if k == name {
                            result = result.push(entry)
                            replaced = true
                            i = i + 1
                            continue
                        }
                    }
                }
            }
        }

        result = result.push(line)
        i = i + 1
    }

    // 섹션 끝까지 키를 못 찾은 경우
    if in_section {
        if !replaced {
            result = result.push(entry)
            replaced = true
        }
    }

    // 섹션 자체가 없는 경우
    if !section_exists {
        if section != "" {
            result = result.push("")
            result = result.push(section_header)
        }
        result = result.push(entry)
    }

    let mut out = ""
    let mut j = 0
    while j < len(result) {
        out = out + result[j] + "\n"
        j = j + 1
    }
    write_file(path, out)
    print("set " + key + " = " + value)
}

// ─── 전체 설정 목록 ───
fn config_list() {
    let parsed = load_config()
    if parsed == "" {
        print("(no config file found at " + config_path() + ")")
        print("run 'hexa config.hexa init' to create default config")
        return
    }
    let lines = parsed.split("\n")
    let mut count = 0
    let mut i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        if line != "" {
            print(line)
            count = count + 1
        }
        i = i + 1
    }
    print("--- " + to_string(count) + " setting(s)")
}

// ─── 섹션별 목록 ───
fn config_section(section_name: string) {
    let parsed = load_config()
    let prefix = section_name + "."
    let lines = parsed.split("\n")
    let mut count = 0
    let mut i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        if line != "" {
            if line.index_of(prefix) == 0 {
                print(line)
                count = count + 1
            }
        }
        i = i + 1
    }
    if count == 0 {
        // 기본값 표시
        print("(no configured values for [" + section_name + "], showing defaults)")
        match section_name {
            "loop" -> {
                print("loop.domain=" + default_loop_domain)
                print("loop.cycles=" + to_string(default_loop_cycles))
                print("loop.max_ouroboros_cycles=" + to_string(default_loop_max_ouroboros))
                print("loop.max_meta_cycles=" + to_string(default_loop_max_meta))
                print("loop.forge_after_n_cycles=" + to_string(default_loop_forge_after))
            },
            "daemon" -> {
                print("daemon.interval_min=" + to_string(default_daemon_interval))
            },
            "blowup" -> {
                print("blowup.domain=" + default_blowup_domain)
                print("blowup.max_depth=" + to_string(default_blowup_depth))
                print("blowup.max_corollaries=" + to_string(default_blowup_max_corollaries))
                print("blowup.min_confidence=" + to_string(default_blowup_min_confidence))
            },
            "evolution" -> {
                print("evolution.serendipity_ratio=" + to_string(default_evolution_serendipity))
                print("evolution.min_verification_score=" + to_string(default_evolution_min_verify))
                print("evolution.max_mutations_per_cycle=" + to_string(default_evolution_max_mutations))
            },
            "forge" -> {
                print("forge.max_candidates=" + to_string(default_forge_max_candidates))
                print("forge.min_confidence=" + to_string(default_forge_min_confidence))
                print("forge.similarity_threshold=" + to_string(default_forge_similarity))
            },
            "log_rotation" -> {
                print("log_rotation.max_bytes=" + to_string(default_log_max_bytes))
                print("log_rotation.max_files=" + to_string(default_log_max_files))
            },
            _ -> {
                print("unknown section: " + section_name)
            }
        }
    } else {
        print("--- " + to_string(count) + " setting(s) in [" + section_name + "]")
    }
}

// ─── 기본 config.toml 생성 ───
fn config_init() {
    let path = config_path()
    let existing = read_file(path)
    if existing != "" {
        print("config already exists at " + path)
        print("use 'set' to modify individual values")
        return
    }
    let template = "# NEXUS-6 Configuration\n# Place this file at ~/.nexus/config.toml\n# All values are optional — hardcoded defaults are shown.\n\n[loop]\n# domain = \"number_theory\"\n# cycles = 1\n# max_ouroboros_cycles = 6\n# max_meta_cycles = 6\n# forge_after_n_cycles = 3\n\n[daemon]\n# domain = \"number_theory\"\n# interval_min = 30\n# max_loops = 0          # 0 = infinite\n\n[blowup]\n# domain = \"number_theory\"\n# max_depth = 6\n# max_corollaries = 216\n# min_confidence = 0.15\n# transfer_domains = [\"physics\", \"mathematics\", \"information\", \"biology\", \"consciousness\", \"architecture\"]\n\n[evolution]\n# domain = \"general\"\n# serendipity_ratio = 0.3\n# min_verification_score = 0.5\n# max_mutations_per_cycle = 20\n\n[forge]\n# max_candidates = 20\n# min_confidence = 0.2\n# similarity_threshold = 0.8\n\n[materials]\n# api_key = \"your-materials-project-api-key\"\n\n[log_rotation]\n# max_bytes = 1048576   # 1 MB\n# max_files = 5\n"
    write_file(path, template)
    print("created default config at " + path)
}

// ─── CLI ───
fn main() {
    let a = args()
    if len(a) < 2 {
        print("config.hexa — configuration file management")
        print("usage:")
        print("  hexa config.hexa get <key>           — get value (section.key format)")
        print("  hexa config.hexa set <key> <value>   — set value")
        print("  hexa config.hexa list                — show all settings")
        print("  hexa config.hexa section <name>      — show section (loop/daemon/blowup/...)")
        print("  hexa config.hexa init                — create default config.toml")
        print("")
        print("sections: loop, daemon, blowup, evolution, forge, materials, log_rotation")
        return
    }
    let cmd = a[1]
    match cmd {
        "get" -> {
            if len(a) < 3 {
                print("usage: hexa config.hexa get <key>")
                return
            }
            let key = a[2]
            let val = config_get(key)
            if val == "" {
                print(key + " = (not set)")
            } else {
                print(key + " = " + val)
            }
        },
        "set" -> {
            if len(a) < 4 {
                print("usage: hexa config.hexa set <key> <value>")
                return
            }
            config_set(a[2], a[3])
        },
        "list" -> {
            config_list()
        },
        "section" -> {
            if len(a) < 3 {
                print("usage: hexa config.hexa section <name>")
                return
            }
            config_section(a[2])
        },
        "init" -> {
            config_init()
        },
        _ -> {
            print("unknown command: " + cmd)
            print("commands: get, set, list, section, init")
        }
    }
}

main()
