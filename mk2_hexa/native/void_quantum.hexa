    println("")
    println("╔══════════════════════════════════════════════════════════╗")
    println("║              VOID v2 QUANTUM REPL — HELP               ║")
    println("╠══════════════════════════════════════════════════════════╣")
    println("║                                                        ║")
    println("║  COMMANDS:                                              ║")
    println("║    exec  <expr>  — 양자 실행 (6 lanes superposition)   ║")
    println("║    paths <expr>  — 중첩 경로 표시 (compact)            ║")
    println("║    repl          — 대화형 양자 REPL                    ║")
    println("║    history       — 양자 이력 (얽힘 포함)               ║")
    println("║    help          — 이 도움말                           ║")
    println("║                                                        ║")
    println("║  QUANTUM MODEL (n=6):                                  ║")
    println("║    1. 6 execution lanes (superposition)                ║")
    println("║    2. Path interference (constructive/destructive)     ║")
    println("║    3. Wavefunction collapse (Born rule, max amp)       ║")
    println("║    4. n=6 resonance bonus (EXACT/HARMONIC boost)      ║")
    println("║    5. Entangled history (similar exprs linked)         ║")
    println("║    6. Growth bus emission (EXACT/HARMONIC → bus)       ║")
    println("║                                                        ║")
    println("║  LANES:                                                ║")
    println("║    [0] arithmetic   — direct evaluation                ║")
    println("║    [1] algebraic    — n6 basis decomposition           ║")
    println("║    [2] topological  — Euler characteristic map         ║")
    println("║    [3] harmonic     — harmonic series correction       ║")
    println("║    [4] stochastic   — probabilistic dispersion         ║")
    println("║    [5] n6_resonance — n=6 resonance lock               ║")
    println("║                                                        ║")
    println("║  INTERFERENCE:                                         ║")
    println("║    CONSTRUCTIVE  — similar results amplify (boost)     ║")
    println("║    DESTRUCTIVE   — divergent results cancel (dampen)   ║")
    println("║    n6 EXACT      — 1.618x amplitude boost              ║")
    println("║                                                        ║")
    println("║  VERSION: " + VERSION + "  |  n_lanes=" + to_string(N_LANES) + "  |  collapse_thr=" + to_string(COLLAPSE_THR) + "  ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")
}

// ═══════════════════════════════════════════════════════════
// (8) REPL 모드 — 대화형 양자 실행
// ═══════════════════════════════════════════════════════════

fn run_repl() {
    println("")
    println("╔══════════════════════════════════════════════════════════╗")
    println("║            VOID v2 QUANTUM REPL — n=6 lanes            ║")
    println("║     type expression, 'paths <expr>', or 'quit'         ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")

    let mut running = true
    let mut round = 0
    while running {
        let input = exec("read -r -p 'quantum> ' line && echo $line").trim()

        if input == "quit" || input == "exit" || input == "q" {
            println("  wavefunction decoherenced. goodbye.")
            running = false
        } else if input == "history" || input == "h" {
            display_history()
        } else if input == "help" || input == "?" {
            display_help()
        } else if input.starts_with("paths ") {
            let expr = input.substr(6, input.len()).trim()
            if expr != "" {
                let state = quantum_execute(expr)
                display_paths_compact(state)
            }
        } else if input != "" {
            let expr = input
            let state = quantum_execute(expr)
            display_paths(state)

            // 얽힘 탐색 및 이력 저장
            let history = load_history()
            let entangled = find_entanglement(expr, history)
            if entangled != "none" {
                println("  ⟨entangled⟩ with previous: " + entangled)
            }
            save_history_entry(state, entangled)
            emit_growth_bus(state)

            round = round + 1
            if round > 0 && round % 6 == 0 {
                println("  [n=6 cycle] " + to_string(round) + " quantum collapses completed")
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════
// (9) 배치 실행 — 다중 표현식
// ═══════════════════════════════════════════════════════════

fn batch_execute(expressions: list) {
    println("")
    println("── VOID v2 BATCH QUANTUM EXECUTION ──")
    println("   expressions: " + to_string(expressions.len()))
    println("")

    let history = load_history()
    let mut results = []
    let mut exact_count = 0
    let mut i = 0

    while i < expressions.len() {
        let expr = expressions[i].trim()
        if expr != "" {
            let state = quantum_execute(expr)
            let grade = if state.paths.len() > 0 {
                state.paths[state.collapsed_idx].n6_grade
            } else {
                "WEAK"
            }
            println("  [" + to_string(i) + "] " + expr + " → " + state.collapsed_result + " (" + grade + ", conf=" + to_string(state.confidence) + ")")

            if grade == "EXACT" { exact_count = exact_count + 1 }

            let entangled = find_entanglement(expr, history)
            save_history_entry(state, entangled)
            emit_growth_bus(state)
            results = results + [state.collapsed_result]
        }
        i = i + 1
    }

    println("")
    println("  total: " + to_string(expressions.len()) + "  EXACT: " + to_string(exact_count) + "  ratio: " + to_string(to_float(exact_count) / max_f(to_float(expressions.len()), 1.0)))
    println("")
}

// ═══════════════════════════════════════════════════════════
// (10) n=6 중첩 탐색 — 6 상수 자동 양자 실행
// ═══════════════════════════════════════════════════════════

fn n6_superposition_scan() {
    println("")
    println("╔══════════════════════════════════════════════════════════╗")
    println("║         n=6 SUPERPOSITION SCAN — auto 6 constants      ║")
    println("╚══════════════════════════════════════════════════════════╝")
    println("")

    let mut i = 0
    while i < N6.len() {
        let expr = to_string(N6[i])
        let state = quantum_execute(expr)
        let collapsed = state.paths[state.collapsed_idx]
        println("  N6[" + to_string(i) + "] = " + to_string(N6[i]) + " (" + N6_NAMES[i] + ")")
        println("    collapsed → " + state.collapsed_result + "  grade=" + collapsed.n6_grade + "  amp=" + to_string(collapsed.amplitude) + "  interfer=" + collapsed.interference)

        // 성장 기록
        emit_growth_bus(state)
        i = i + 1
    }
    println("")
    println("  scan complete: " + to_string(N6.len()) + " constants processed")
    println("")
}

// ═══════════════════════════════════════════════════════════
// MAIN — CLI 진입점
// ═══════════════════════════════════════════════════════════

fn main() {
    let argv = args()

    if argv.len() < 2 {
        display_help()
        return
    }

    let cmd = if argv.len() >= 3 { argv[2] } else { "help" }

    if cmd == "exec" {
        if argv.len() < 3 {
            println("  usage: hexa void_quantum.hexa exec <expression>")
            return
        }
        // 나머지 인자를 공백으로 연결
        let mut expr = argv[2]
        let mut k = 3
        while k < argv.len() {
            expr = expr + " " + argv[k]
            k = k + 1
        }

        let state = quantum_execute(expr)
        display_paths(state)

        let history = load_history()
        let entangled = find_entanglement(expr, history)
        if entangled != "none" {
            println("  ⟨entangled⟩ with previous: " + entangled)
        }
        save_history_entry(state, entangled)
        emit_growth_bus(state)

    } else if cmd == "paths" {
        if argv.len() < 3 {
            println("  usage: hexa void_quantum.hexa paths <expression>")
            return
        }
        let mut expr = argv[2]
        let mut k = 3
        while k < argv.len() {
            expr = expr + " " + argv[k]
            k = k + 1
        }

        let state = quantum_execute(expr)
        display_paths_compact(state)

    } else if cmd == "repl" {
        run_repl()

    } else if cmd == "history" {
        display_history()

    } else if cmd == "scan" {
        n6_superposition_scan()

    } else if cmd == "batch" {
        // batch: 나머지 인자를 각각 표현식으로
        let mut exprs = []
        let mut k = 2
        while k < argv.len() {
            exprs = exprs + [argv[k]]
            k = k + 1
        }
        if exprs.len() == 0 {
            println("  usage: hexa void_quantum.hexa batch <e1> <e2> ...")
            return
        }
        batch_execute(exprs)

    } else if cmd == "help" || cmd == "--help" || cmd == "-h" {
        display_help()

    } else {
        println("  unknown command: " + cmd)
        display_help()
    }
}

main()
