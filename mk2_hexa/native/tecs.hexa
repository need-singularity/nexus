// mk2_hexa/native/tecs.hexa — TECS-L math acceleration (hexa-native port)
// Rust 원본: shared/tecsrs/src/*.rs (9 modules)
// 실행: hexa mk2_hexa/native/tecs.hexa <command> [args]
//
// Commands:
//   sieve <limit>                 — arithmetic function sieves (sigma,tau,phi,sopfr,omega,lpf)
//   sieve <limit> <n>             — lookup single value for all functions
//   monte <n_trials> [seed]       — Texas Sharpshooter test (simplified)
//   bootstrap <data...>           — bootstrap confidence interval for mean
//   ode <system> [steps] [dt]     — ODE attractor simulation (lorenz|rossler|chen|chua)
//   grid <size> [threshold]       — GZ ratio grid scan (D*P/I)
//   perfect <n>                   — perfect number analysis + sigma chain
//   search <depth> [threshold]    — DFS expression search (default constants/targets)
//   atlas <dir>                   — scan hypothesis markdown files
//   psi                           — PSI consciousness constants
//   psi_verify                    — PSI self-consistency verification
//   conservation [h0] [rate]      — conservation trajectory H^2 + dH^2
//   gate <corpus_mb>              — gate formula (Law 77)
//   genetic <stops> <amino_acids> — genetic code n=6 test
//   help                          — this help text
//
// All algorithms ported from Rust/PyO3 originals with mathematical correctness.

// ═══════════════════════════════════════════════════════════
// ─── UTILITIES ───
// ═══════════════════════════════════════════════════════════

fn safe_float(s: string) -> f64 {
    let mut v = 0.0
    try { v = to_float(s) } catch e {}
    return v
}

fn safe_int(s: string) -> i64 {
    let mut v = 0
    try { v = to_int(s) } catch e {}
    return v
}

fn abs_f(x: f64) -> f64 {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_f(a: f64, b: f64) -> f64 {
    if a > b { return a }
    return b
}

fn min_f(a: f64, b: f64) -> f64 {
    if a < b { return a }
    return b
}

fn max_i(a: i64, b: i64) -> i64 {
    if a > b { return a }
    return b
}

fn min_i(a: i64, b: i64) -> i64 {
    if a < b { return a }
    return b
}

fn sqrt_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i: i64 = 0
    while i < 20 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

fn ln_f(x: f64) -> f64 {
    if x <= 0.0 { return 0.0 - 999999.0 }
    // Reduce x to [0.5, 2.0] range for convergence
    let mut r = 0.0
    let mut v = x
    while v > 2.0 {
        v = v / 2.718281828459045
        r = r + 1.0
    }
    while v < 0.5 {
        v = v * 2.718281828459045
        r = r - 1.0
    }
    // Series around 1: ln(v) = 2 * sum( ((v-1)/(v+1))^(2k+1) / (2k+1) )
    let mut sum = 0.0
    let term0 = (v - 1.0) / (v + 1.0)
    let t2 = term0 * term0
    let mut term = term0
    let mut k: i64 = 1
    while k <= 25 {
        sum = sum + term / to_float(k)
        term = term * t2
        k = k + 2
    }
    return 2.0 * sum + r
}

fn exp_f(x: f64) -> f64 {
    if x > 500.0 { return 999999999.0 }
    if x < 0.0 - 500.0 { return 0.0 }
    // exp(x) via Taylor series: 1 + x + x^2/2! + ...
    let mut sum = 1.0
    let mut term = 1.0
    let mut k: i64 = 1
    while k <= 30 {
        term = term * x / to_float(k)
        sum = sum + term
        if abs_f(term) < 0.000000000000001 { k = 31 }
        k = k + 1
    }
    return sum
}

fn pow_f(base: f64, exp_val: f64) -> f64 {
    if base <= 0.0 { return 0.0 }
    return exp_f(exp_val * ln_f(base))
}

fn floor_i(x: f64) -> i64 {
    let i = to_int(to_string(x).split(".")[0])
    return i
}

// Simple LCG pseudo-random number generator
// state stored as mutable i64, returns f64 in [0, 1)
fn rng_next(state: i64) -> i64 {
    // LCG: next = (a * state + c) mod m
    let a: i64 = 1103515245
    let c: i64 = 12345
    let m: i64 = 2147483647
    let mut next = a * state + c
    if next < 0 { next = 0 - next }
    next = next % m
    return next
}

fn rng_float(state: i64) -> f64 {
    let s = rng_next(state)
    return to_float(s) / 2147483647.0
}

fn factorial(n: i64) -> i64 {
    if n <= 1 { return 1 }
    if n > 20 { return 9223372036854775807 }
    let mut result: i64 = 1
    let mut k: i64 = 2
    while k <= n {
        result = result * k
        k = k + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 1: SIEVES (trial division per number) ───
// ═══════════════════════════════════════════════════════════

// sigma(n) = sum of divisors — trial division
fn sigma_td(n: i64) -> i64 {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    let mut result: i64 = 0
    let mut d: i64 = 1
    while d * d <= n {
        if n % d == 0 {
            result = result + d
            if d != n / d { result = result + n / d }
        }
        d = d + 1
    }
    return result
}

// tau(n) = number of divisors
fn tau_td(n: i64) -> i64 {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    let mut count: i64 = 0
    let mut d: i64 = 1
    while d * d <= n {
        if n % d == 0 {
            count = count + 1
            if d != n / d { count = count + 1 }
        }
        d = d + 1
    }
    return count
}

// phi(n) = Euler totient
fn phi_td(n: i64) -> i64 {
    if n <= 1 { return n }
    let mut result = n
    let mut temp = n
    let mut p: i64 = 2
    while p * p <= temp {
        if temp % p == 0 {
            while temp % p == 0 { temp = temp / p }
            result = result - result / p
        }
        p = p + 1
    }
    if temp > 1 { result = result - result / temp }
    return result
}

// sopfr(n) = sum of prime factors with repetition
fn sopfr_td(n: i64) -> i64 {
    if n <= 1 { return 0 }
    let mut result: i64 = 0
    let mut temp = n
    let mut p: i64 = 2
    while p * p <= temp {
        while temp % p == 0 {
            result = result + p
            temp = temp / p
        }
        p = p + 1
    }
    if temp > 1 { result = result + temp }
    return result
}

// omega(n) = number of distinct prime factors
fn omega_td(n: i64) -> i64 {
    if n <= 1 { return 0 }
    let mut count: i64 = 0
    let mut temp = n
    let mut p: i64 = 2
    while p * p <= temp {
        if temp % p == 0 {
            count = count + 1
            while temp % p == 0 { temp = temp / p }
        }
        p = p + 1
    }
    if temp > 1 { count = count + 1 }
    return count
}

// lpf(n) = largest prime factor
fn lpf_td(n: i64) -> i64 {
    if n <= 1 { return 0 }
    let mut largest: i64 = 0
    let mut temp = n
    let mut p: i64 = 2
    while p * p <= temp {
        while temp % p == 0 {
            if p > largest { largest = p }
            temp = temp / p
        }
        p = p + 1
    }
    if temp > 1 {
        if temp > largest { largest = temp }
    }
    return largest
}

// spf(n) = smallest prime factor
fn spf_td(n: i64) -> i64 {
    if n <= 1 { return 0 }
    let mut p: i64 = 2
    while p * p <= n {
        if n % p == 0 { return p }
        p = p + 1
    }
    return n
}

fn run_sieve(limit: i64, query_n: i64) {
    println("=== TECS Arithmetic Sieves (limit=" + to_string(limit) + ") ===")

    if query_n > 0 {
        if query_n > limit {
            println("ERROR: n=" + to_string(query_n) + " exceeds limit=" + to_string(limit))
            return
        }
        let n = query_n
        println("n=" + to_string(n))
        println("  sigma(" + to_string(n) + ") = " + to_string(sigma_td(n)))
        println("  tau(" + to_string(n) + ")   = " + to_string(tau_td(n)))
        println("  phi(" + to_string(n) + ")   = " + to_string(phi_td(n)))
        println("  sopfr(" + to_string(n) + ") = " + to_string(sopfr_td(n)))
        println("  lpf(" + to_string(n) + ")   = " + to_string(lpf_td(n)))
        println("  omega(" + to_string(n) + ") = " + to_string(omega_td(n)))
        // Perfect number check
        if sigma_td(n) == 2 * n {
            println("  *** PERFECT NUMBER ***")
        }
        // Abundancy
        let abund = to_float(sigma_td(n)) / to_float(n)
        println("  abundancy = " + to_string(abund))
        return
    }

    // Print first 30
    println("")
    println("n\tsigma\ttau\tphi\tsopfr\tlpf\tomega")
    let mut n: i64 = 1
    while n <= min_i(30, limit) {
        println(to_string(n) + "\t" + to_string(sigma_td(n)) + "\t" + to_string(tau_td(n)) + "\t" + to_string(phi_td(n)) + "\t" + to_string(sopfr_td(n)) + "\t" + to_string(lpf_td(n)) + "\t" + to_string(omega_td(n)))
        n = n + 1
    }

    // Count primes
    let mut prime_count: i64 = 0
    n = 2
    while n <= limit {
        if spf_td(n) == n { prime_count = prime_count + 1 }
        n = n + 1
    }
    println("")
    println("Primes up to " + to_string(limit) + ": " + to_string(prime_count))

    // Perfect numbers
    println("Perfect numbers up to " + to_string(limit) + ":")
    n = 2
    while n <= limit {
        if sigma_td(n) == 2 * n {
            println("  " + to_string(n))
        }
        n = n + 1
    }
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 3: MONTE CARLO ───
// ═══════════════════════════════════════════════════════════

fn texas_sharpshooter(real_hits: i64, n_trials: i64, seed: i64) {
    println("=== Texas Sharpshooter Test ===")
    println("real_hits=" + to_string(real_hits) + " n_trials=" + to_string(n_trials))

    // Default targets (key mathematical/physical constants)
    let targets = [0.5772156649, 0.9159655941, 1.2020569031, 4.6692016091, 2.5029078751, 0.6601618158, 1.4142135624, 1.7320508076, 0.00729735, 2.725, 0.683, 0.268]
    let tol = 0.01

    let mut rng_state = seed
    let mut random_hits = []
    let mut trial: i64 = 0

    while trial < n_trials {
        // Generate 14 random constants in various scales
        let mut consts = []
        let scales = [0.01, 0.1, 1.0, 10.0, 100.0]
        let mut ci: i64 = 0
        while ci < 14 {
            rng_state = rng_next(rng_state)
            let mut scale_idx = rng_state % 5
            if scale_idx < 0 { scale_idx = 0 - scale_idx }
            rng_state = rng_next(rng_state)
            let rv = to_float(rng_state) / 2147483647.0
            let val = rv * scales[scale_idx] * 2.0
            consts = consts.push(val)
            ci = ci + 1
        }

        // Count how many targets are hit by single constant or binary op
        let mut hits: i64 = 0
        let mut ti: i64 = 0
        while ti < targets.len() {
            let tgt = targets[ti]
            let mut found = false
            // Single constant match
            let mut ci2: i64 = 0
            while ci2 < consts.len() {
                let rel_err = abs_f(consts[ci2] - tgt) / max_f(abs_f(tgt), 0.000000000000001)
                if rel_err < tol { found = true }
                ci2 = ci2 + 1
            }
            // Binary ops (simplified: just +, -, *, / between first 8 pairs)
            if found == false {
                let mut ai: i64 = 0
                while ai < min_i(8, consts.len()) {
                    let mut bi: i64 = 0
                    while bi < min_i(8, consts.len()) {
                        if ai != bi {
                            let a = consts[ai]
                            let b = consts[bi]
                            // a+b
                            let rel1 = abs_f(a + b - tgt) / max_f(abs_f(tgt), 0.000000000000001)
                            if rel1 < tol { found = true }
                            // a-b
                            let rel2 = abs_f(a - b - tgt) / max_f(abs_f(tgt), 0.000000000000001)
                            if rel2 < tol { found = true }
                            // a*b
                            let rel3 = abs_f(a * b - tgt) / max_f(abs_f(tgt), 0.000000000000001)
                            if rel3 < tol { found = true }
                            // a/b
                            if abs_f(b) > 0.000000000000001 {
                                let rel4 = abs_f(a / b - tgt) / max_f(abs_f(tgt), 0.000000000000001)
                                if rel4 < tol { found = true }
                            }
                        }
                        bi = bi + 1
                    }
                    ai = ai + 1
                }
            }
            if found { hits = hits + 1 }
            ti = ti + 1
        }
        random_hits = random_hits.push(hits)
        trial = trial + 1
    }

    // Statistics
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < random_hits.len() {
        sum = sum + to_float(random_hits[i])
        i = i + 1
    }
    let mean = sum / to_float(n_trials)

    let mut var_sum = 0.0
    i = 0
    while i < random_hits.len() {
        let d = to_float(random_hits[i]) - mean
        var_sum = var_sum + d * d
        i = i + 1
    }
    let std = sqrt_f(var_sum / to_float(n_trials))

    let mut count_ge: i64 = 0
    i = 0
    while i < random_hits.len() {
        if random_hits[i] >= real_hits { count_ge = count_ge + 1 }
        i = i + 1
    }
    let p_value = to_float(count_ge) / to_float(n_trials)

    let mut z_score = 0.0
    if std > 0.0 { z_score = (to_float(real_hits) - mean) / std }

    println("")
    println("Results:")
    println("  real_hits:    " + to_string(real_hits))
    println("  random_mean:  " + to_string(mean))
    println("  random_std:   " + to_string(std))
    println("  p_value:      " + to_string(p_value))
    println("  z_score:      " + to_string(z_score))
    if p_value < 0.05 {
        println("  verdict:      SIGNIFICANT (p < 0.05)")
    } else {
        println("  verdict:      NOT SIGNIFICANT")
    }
}

fn bootstrap_ci(data: list, n_boot: i64, seed: i64) {
    println("=== Bootstrap Confidence Interval (95%) ===")
    let n = data.len()
    if n == 0 {
        println("ERROR: empty data")
        return
    }

    // Compute estimate (mean)
    let mut sum = 0.0
    let mut i: i64 = 0
    while i < n {
        sum = sum + data[i]
        i = i + 1
    }
    let estimate = sum / to_float(n)

    // Bootstrap resampling
    let mut boot_means = []
    let mut rng_state = seed
    let mut b: i64 = 0
    while b < n_boot {
        let mut bsum = 0.0
        let mut j: i64 = 0
        while j < n {
            rng_state = rng_next(rng_state)
            let mut idx = rng_state % n
            if idx < 0 { idx = 0 - idx }
            bsum = bsum + data[idx]
            j = j + 1
        }
        boot_means = boot_means.push(bsum / to_float(n))
        b = b + 1
    }

    // Compute CI using mean +/- 1.96*std of bootstrap means (normal approx)
    let mut bm_sum = 0.0
    let mut bm_sq = 0.0
    let mut bi2: i64 = 0
    while bi2 < boot_means.len() {
        bm_sum = bm_sum + boot_means[bi2]
        bm_sq = bm_sq + boot_means[bi2] * boot_means[bi2]
        bi2 = bi2 + 1
    }
    let bm_mean = bm_sum / to_float(n_boot)
    let bm_std = sqrt_f(max_f(bm_sq / to_float(n_boot) - bm_mean * bm_mean, 0.0))
    let ci_lo = bm_mean - 1.96 * bm_std
    let ci_hi = bm_mean + 1.96 * bm_std

    println("  n:          " + to_string(n))
    println("  estimate:   " + to_string(estimate))
    println("  ci_lo:      " + to_string(ci_lo))
    println("  ci_hi:      " + to_string(ci_hi))
    println("  n_boot:     " + to_string(n_boot))
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 5: ODE INTEGRATORS ───
// ═══════════════════════════════════════════════════════════

// Lorenz: dx/dt = sigma*(y-x), dy/dt = x*(rho-z)-y, dz/dt = x*y - beta*z
fn ode_lorenz(steps: i64, dt: f64) {
    println("=== Lorenz Attractor (RK4) ===")
    let sigma_l = 10.0
    let rho = 28.0
    let beta = 2.6667

    let mut x = 1.0
    let mut y = 1.0
    let mut z = 1.0

    let mut x_sum = 0.0
    let mut x_sq_sum = 0.0

    println("step\tx\ty\tz")
    let mut step: i64 = 0
    while step < steps {
        // RK4 integration
        let dx1 = sigma_l * (y - x)
        let dy1 = x * (rho - z) - y
        let dz1 = x * y - beta * z

        let x2 = x + dx1 * dt * 0.5
        let y2 = y + dy1 * dt * 0.5
        let z2 = z + dz1 * dt * 0.5
        let dx2 = sigma_l * (y2 - x2)
        let dy2 = x2 * (rho - z2) - y2
        let dz2 = x2 * y2 - beta * z2

        let x3 = x + dx2 * dt * 0.5
        let y3 = y + dy2 * dt * 0.5
        let z3 = z + dz2 * dt * 0.5
        let dx3 = sigma_l * (y3 - x3)
        let dy3 = x3 * (rho - z3) - y3
        let dz3 = x3 * y3 - beta * z3

        let x4 = x + dx3 * dt
        let y4 = y + dy3 * dt
        let z4 = z + dz3 * dt
        let dx4 = sigma_l * (y4 - x4)
        let dy4 = x4 * (rho - z4) - y4
        let dz4 = x4 * y4 - beta * z4

        x = x + (dx1 + 2.0 * dx2 + 2.0 * dx3 + dx4) * dt / 6.0
        y = y + (dy1 + 2.0 * dy2 + 2.0 * dy3 + dy4) * dt / 6.0
        z = z + (dz1 + 2.0 * dz2 + 2.0 * dz3 + dz4) * dt / 6.0

        x_sum = x_sum + x
        x_sq_sum = x_sq_sum + x * x

        // Print every 1/10 of steps
        if step % max_i(steps / 10, 1) == 0 {
            println(to_string(step) + "\t" + to_string(x) + "\t" + to_string(y) + "\t" + to_string(z))
        }
        step = step + 1
    }

    let x_mean = x_sum / to_float(steps)
    let x_std = sqrt_f(x_sq_sum / to_float(steps) - x_mean * x_mean)

    println("")
    println("Final state: x=" + to_string(x) + " y=" + to_string(y) + " z=" + to_string(z))
    println("x_mean=" + to_string(x_mean) + " x_std=" + to_string(x_std))

    // Estimate Lyapunov exponent (simplified)
    let eps = 0.00000001
    let dx_n = sigma_l * (y - x)
    let dy_n = x * (rho - z) - y
    let dz_n = x * y - beta * z
    let dx_p = sigma_l * (y - (x + eps))
    let dy_p = (x + eps) * (rho - z) - y
    let dz_p = (x + eps) * y - beta * z
    let stretch = sqrt_f((dx_p - dx_n) * (dx_p - dx_n) + (dy_p - dy_n) * (dy_p - dy_n) + (dz_p - dz_n) * (dz_p - dz_n)) / eps
    if stretch > 0.0 {
        println("Lyapunov estimate (final point): " + to_string(ln_f(stretch)))
    }
}

fn ode_rossler(steps: i64, dt: f64) {
    println("=== Rossler Attractor (RK4) ===")
    let a = 0.2
    let b = 0.2
    let c = 5.7

    let mut x = 1.0
    let mut y = 1.0
    let mut z = 0.0

    let mut step: i64 = 0
    println("step\tx\ty\tz")
    while step < steps {
        let dx1 = 0.0 - y - z
        let dy1 = x + a * y
        let dz1 = b + z * (x - c)

        let x2 = x + dx1 * dt * 0.5
        let y2 = y + dy1 * dt * 0.5
        let z2 = z + dz1 * dt * 0.5
        let dx2 = 0.0 - y2 - z2
        let dy2 = x2 + a * y2
        let dz2 = b + z2 * (x2 - c)

        let x3 = x + dx2 * dt * 0.5
        let y3 = y + dy2 * dt * 0.5
        let z3 = z + dz2 * dt * 0.5
        let dx3 = 0.0 - y3 - z3
        let dy3 = x3 + a * y3
        let dz3 = b + z3 * (x3 - c)

        let x4 = x + dx3 * dt
        let y4 = y + dy3 * dt
        let z4 = z + dz3 * dt
        let dx4 = 0.0 - y4 - z4
        let dy4 = x4 + a * y4
        let dz4 = b + z4 * (x4 - c)

        x = x + (dx1 + 2.0 * dx2 + 2.0 * dx3 + dx4) * dt / 6.0
        y = y + (dy1 + 2.0 * dy2 + 2.0 * dy3 + dy4) * dt / 6.0
        z = z + (dz1 + 2.0 * dz2 + 2.0 * dz3 + dz4) * dt / 6.0

        if step % max_i(steps / 10, 1) == 0 {
            println(to_string(step) + "\t" + to_string(x) + "\t" + to_string(y) + "\t" + to_string(z))
        }
        step = step + 1
    }
    println("")
    println("Final state: x=" + to_string(x) + " y=" + to_string(y) + " z=" + to_string(z))
}

fn ode_chen(steps: i64, dt: f64) {
    println("=== Chen Attractor (RK4) ===")
    let a = 35.0
    let b = 3.0
    let c = 28.0

    let mut x = 1.0
    let mut y = 1.0
    let mut z = 1.0

    let mut step: i64 = 0
    println("step\tx\ty\tz")
    while step < steps {
        let dx1 = a * (y - x)
        let dy1 = (c - a) * x - x * z + c * y
        let dz1 = x * y - b * z

        let x2 = x + dx1 * dt * 0.5
        let y2 = y + dy1 * dt * 0.5
        let z2 = z + dz1 * dt * 0.5
        let dx2 = a * (y2 - x2)
        let dy2 = (c - a) * x2 - x2 * z2 + c * y2
        let dz2 = x2 * y2 - b * z2

        let x3 = x + dx2 * dt * 0.5
        let y3 = y + dy2 * dt * 0.5
        let z3 = z + dz2 * dt * 0.5
        let dx3 = a * (y3 - x3)
        let dy3 = (c - a) * x3 - x3 * z3 + c * y3
        let dz3 = x3 * y3 - b * z3

        let x4 = x + dx3 * dt
        let y4 = y + dy3 * dt
        let z4 = z + dz3 * dt
        let dx4 = a * (y4 - x4)
        let dy4 = (c - a) * x4 - x4 * z4 + c * y4
        let dz4 = x4 * y4 - b * z4

        x = x + (dx1 + 2.0 * dx2 + 2.0 * dx3 + dx4) * dt / 6.0
        y = y + (dy1 + 2.0 * dy2 + 2.0 * dy3 + dy4) * dt / 6.0
        z = z + (dz1 + 2.0 * dz2 + 2.0 * dz3 + dz4) * dt / 6.0

        if step % max_i(steps / 10, 1) == 0 {
            println(to_string(step) + "\t" + to_string(x) + "\t" + to_string(y) + "\t" + to_string(z))
        }
        step = step + 1
    }
    println("")
    println("Final state: x=" + to_string(x) + " y=" + to_string(y) + " z=" + to_string(z))
}

fn ode_chua(steps: i64, dt: f64) {
    println("=== Chua Attractor (RK4) ===")
    let alpha = 15.6
    let beta_c = 28.0
    let m0 = 0.0 - 1.143
    let m1 = 0.0 - 0.714

    let mut x = 0.1
    let mut y = 0.0
    let mut z = 0.0

    let mut step: i64 = 0
    let dt_c = 0.001
    println("step\tx\ty\tz")
    while step < steps {
        // Chua diode function
        let fx1 = m1 * x + 0.5 * (m0 - m1) * (abs_f(x + 1.0) - abs_f(x - 1.0))
        let dx1 = alpha * (y - x - fx1)
        let dy1 = x - y + z
        let dz1 = 0.0 - beta_c * y

        let x2 = x + dx1 * dt_c * 0.5
        let y2 = y + dy1 * dt_c * 0.5
        let z2 = z + dz1 * dt_c * 0.5
        let fx2 = m1 * x2 + 0.5 * (m0 - m1) * (abs_f(x2 + 1.0) - abs_f(x2 - 1.0))
        let dx2 = alpha * (y2 - x2 - fx2)
        let dy2 = x2 - y2 + z2
        let dz2 = 0.0 - beta_c * y2

        let x3 = x + dx2 * dt_c * 0.5
        let y3 = y + dy2 * dt_c * 0.5
        let z3 = z + dz2 * dt_c * 0.5
        let fx3 = m1 * x3 + 0.5 * (m0 - m1) * (abs_f(x3 + 1.0) - abs_f(x3 - 1.0))
        let dx3 = alpha * (y3 - x3 - fx3)
        let dy3 = x3 - y3 + z3
        let dz3 = 0.0 - beta_c * y3

        let x4 = x + dx3 * dt_c
        let y4 = y + dy3 * dt_c
        let z4 = z + dz3 * dt_c
        let fx4 = m1 * x4 + 0.5 * (m0 - m1) * (abs_f(x4 + 1.0) - abs_f(x4 - 1.0))
        let dx4 = alpha * (y4 - x4 - fx4)
        let dy4 = x4 - y4 + z4
        let dz4 = 0.0 - beta_c * y4

        x = x + (dx1 + 2.0 * dx2 + 2.0 * dx3 + dx4) * dt_c / 6.0
        y = y + (dy1 + 2.0 * dy2 + 2.0 * dy3 + dy4) * dt_c / 6.0
        z = z + (dz1 + 2.0 * dz2 + 2.0 * dz3 + dz4) * dt_c / 6.0

        if step % max_i(steps / 10, 1) == 0 {
            println(to_string(step) + "\t" + to_string(x) + "\t" + to_string(y) + "\t" + to_string(z))
        }
        step = step + 1
    }
    println("")
    println("Final state: x=" + to_string(x) + " y=" + to_string(y) + " z=" + to_string(z))
}

fn run_ode(system: string, steps: i64, dt: f64) {
    if system == "lorenz" { ode_lorenz(steps, dt) }
    else if system == "rossler" { ode_rossler(steps, dt) }
    else if system == "chen" { ode_chen(steps, dt) }
    else if system == "chua" { ode_chua(steps, dt) }
    else if system == "all" {
        ode_lorenz(steps, dt)
        println("")
        ode_rossler(steps, dt)
        println("")
        ode_chen(steps, dt)
        println("")
        ode_chua(steps, dt)
    } else {
        println("Unknown ODE system: " + system)
        println("Available: lorenz, rossler, chen, chua, all")
    }
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 4: GRID SCAN ───
// ═══════════════════════════════════════════════════════════

fn run_grid(grid: i64, threshold: f64) {
    println("=== GZ Ratio Grid Scan (grid=" + to_string(grid) + ", threshold=" + to_string(threshold) + ") ===")
    println("Formula: G = D*P/I, condition: G > threshold")

    let mut count: i64 = 0
    let mut sum = 0.0
    let mut sum_sq = 0.0
    let total = grid * grid * grid

    let mut di: i64 = 0
    while di < grid {
        let d = 0.01 + 0.98 * to_float(di) / to_float(max_i(grid - 1, 1))
        let mut pi: i64 = 0
        while pi < grid {
            let p = 0.01 + 0.98 * to_float(pi) / to_float(max_i(grid - 1, 1))
            let mut ii: i64 = 0
            while ii < grid {
                let inh = 0.05 + 0.94 * to_float(ii) / to_float(max_i(grid - 1, 1))
                let g = d * p / inh
                sum = sum + g
                sum_sq = sum_sq + g * g
                if g > threshold { count = count + 1 }
                ii = ii + 1
            }
            pi = pi + 1
        }
        di = di + 1
    }

    let ratio = to_float(count) / to_float(total)
    let mean = sum / to_float(total)
    let var_val = sum_sq / to_float(total) - mean * mean
    let std = sqrt_f(max_f(var_val, 0.0))

    println("")
    println("Results:")
    println("  ratio:   " + to_string(ratio))
    println("  count:   " + to_string(count) + " / " + to_string(total))
    println("  mean(G): " + to_string(mean))
    println("  std(G):  " + to_string(std))
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 7: PERFECT NUMBERS ───
// ═══════════════════════════════════════════════════════════

// sigma_trial, tau_trial, phi_trial = aliases for _td versions
fn sigma_trial(n: i64) -> i64 { return sigma_td(n) }
fn tau_trial(n: i64) -> i64 { return tau_td(n) }
fn phi_trial(n: i64) -> i64 { return phi_td(n) }

fn is_triangular(n: i64) -> i64 {
    // Returns m if n = m(m+1)/2, else -1
    let disc = 1 + 8 * n
    let s = floor_i(sqrt_f(to_float(disc)))
    let mut check = s - 1
    while check <= s + 1 {
        if check * check == disc {
            if (check - 1) % 2 == 0 {
                return (check - 1) / 2
            }
        }
        check = check + 1
    }
    return 0 - 1
}

fn is_factorial(n: i64) -> i64 {
    // Returns k if n = k!, else -1
    if n == 1 { return 1 }
    let mut k: i64 = 2
    let mut fact: i64 = 2
    while fact < n {
        k = k + 1
        fact = fact * k
        if fact > 999999999999 { return 0 - 1 }
    }
    if fact == n { return k }
    return 0 - 1
}

fn is_prime(n: i64) -> bool {
    if n < 2 { return false }
    if n < 4 { return true }
    if n % 2 == 0 { return false }
    if n % 3 == 0 { return false }
    let mut i: i64 = 5
    while i * i <= n {
        if n % i == 0 { return false }
        if n % (i + 2) == 0 { return false }
        i = i + 6
    }
    return true
}

fn run_perfect(n: i64) {
    println("=== Perfect Number Analysis: n=" + to_string(n) + " ===")

    let s = sigma_trial(n)
    let t = tau_trial(n)
    let p = phi_trial(n)

    println("sigma(" + to_string(n) + ") = " + to_string(s))
    println("tau(" + to_string(n) + ")   = " + to_string(t))
    println("phi(" + to_string(n) + ")   = " + to_string(p))
    println("abundancy     = " + to_string(to_float(s) / to_float(n)))

    if s == 2 * n {
        println("*** PERFECT NUMBER ***")
    } else if s > 2 * n {
        println("Abundant number (sigma > 2n)")
    } else {
        println("Deficient number (sigma < 2n)")
    }

    let tri = is_triangular(n)
    if tri >= 0 {
        println("Triangular number: T(" + to_string(tri) + ")")
    }
    let fac = is_factorial(n)
    if fac >= 0 {
        println("Factorial: " + to_string(fac) + "!")
    }

    // Sigma chain
    println("")
    println("Sigma chain: sigma^k(" + to_string(n) + ")")
    let mut current = n
    let mut step: i64 = 0
    while step <= 15 {
        let sc = sigma_trial(current)
        let tc = tau_trial(current)
        let pc = phi_trial(current)
        let abund = to_float(sc) / to_float(current)
        let perf_str = if sc == 2 * current { " [PERFECT]" } else { "" }
        println("  step " + to_string(step) + ": n=" + to_string(current) + " sigma=" + to_string(sc) + " tau=" + to_string(tc) + " phi=" + to_string(pc) + " abundancy=" + to_string(abund) + perf_str)
        if sc > 10000000000 { step = 16 }
        current = sc
        step = step + 1
    }

    // Consciousness bridges (for perfect numbers)
    if s == 2 * n {
        println("")
        println("Consciousness bridges:")
        // Lyapunov product: product of R(d|n) for all d dividing n
        let mut lyap_prod = 1.0
        let mut d: i64 = 1
        while d * d <= n {
            if n % d == 0 {
                let sd = sigma_trial(d)
                let td = tau_trial(d)
                let pd = phi_trial(d)
                if d * td > 0 {
                    lyap_prod = lyap_prod * to_float(sd * pd) / to_float(d * td)
                }
                if d != n / d {
                    let d2 = n / d
                    let sd2 = sigma_trial(d2)
                    let td2 = tau_trial(d2)
                    let pd2 = phi_trial(d2)
                    if d2 * td2 > 0 {
                        lyap_prod = lyap_prod * to_float(sd2 * pd2) / to_float(d2 * td2)
                    }
                }
            }
            d = d + 1
        }
        println("  Lyapunov (Lambda-1): " + to_string(lyap_prod - 1.0))
        println("  sigma/phi:           " + to_string(to_float(s) / to_float(max_i(p, 1))))
        if n * t > 0 {
            println("  R-factor (S*P/n*T):  " + to_string(to_float(s * p) / to_float(n * t)))
        }
        println("  self-measurement:    " + to_string(t))
    }
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 2: DFS SEARCH (simplified) ───
// ═══════════════════════════════════════════════════════════

fn run_search(depth: i64, threshold: f64) {
    println("=== DFS Expression Search (depth=" + to_string(depth) + ", threshold=" + to_string(threshold) + ") ===")

    // Constants pool: name, value pairs encoded as "name:value"
    let consts = []
    // Island A: Rational
    let consts = consts.push("1/2:0.5")
    let consts = consts.push("1/3:0.333333333333")
    let consts = consts.push("1/6:0.166666666667")
    let consts = consts.push("2/3:0.666666666667")
    // Island B: Integer
    let consts = consts.push("6:6.0")
    let consts = consts.push("12:12.0")
    let consts = consts.push("137:137.0")
    let consts = consts.push("720:720.0")
    // Island C: Log
    let consts = consts.push("ln2:0.693147180560")
    let consts = consts.push("ln3:1.098612288668")
    // Island D: Transcendental
    let consts = consts.push("e:2.718281828459")
    let consts = consts.push("pi:3.141592653590")
    let consts = consts.push("phi:1.618033988750")

    // Targets
    let targets = []
    let targets = targets.push("euler_gamma:0.5772156649")
    let targets = targets.push("catalan:0.9159655941")
    let targets = targets.push("apery:1.2020569031")
    let targets = targets.push("feigenbaum_delta:4.6692016091")
    let targets = targets.push("sqrt2:1.4142135624")
    let targets = targets.push("sqrt3:1.7320508076")
    let targets = targets.push("alpha_em:0.00729735")
    let targets = targets.push("dark_energy:0.683")
    let targets = targets.push("dark_matter:0.268")

    // Build expression pool: level 0 = constants
    let mut pool_v = []
    let mut pool_n = []
    let mut ci: i64 = 0
    while ci < consts.len() {
        let parts = consts[ci].split(":")
        let name = parts[0]
        let val = safe_float(parts[1])
        pool_v = pool_v.push(val)
        pool_n = pool_n.push(name)
        // Unary: 1/x, sqrt, ln
        if abs_f(val) > 0.000000000000001 {
            pool_v = pool_v.push(1.0 / val)
            pool_n = pool_n.push("1/" + name)
        }
        if val > 0.0 {
            pool_v = pool_v.push(sqrt_f(val))
            pool_n = pool_n.push("sqrt(" + name + ")")
            pool_v = pool_v.push(ln_f(val))
            pool_n = pool_n.push("ln(" + name + ")")
        }
        ci = ci + 1
    }

    let base_len = pool_v.len()

    // Build depth levels: combine pool x base
    let mut d_level: i64 = 0
    while d_level < depth {
        let cur_len = pool_v.len()
        let mut ai: i64 = 0
        while ai < cur_len {
            let mut bi: i64 = 0
            while bi < base_len {
                let av = pool_v[ai]
                let bv = pool_v[bi]
                let an = pool_n[ai]
                let bn = pool_n[bi]
                // + pool_v = pool_v.push(av + bv)
                pool_n = pool_n.push("(" + an + "+" + bn + ")")
                // -
                pool_v = pool_v.push(av - bv)
                pool_n = pool_n.push("(" + an + "-" + bn + ")")
                // *
                let v_mul = av * bv
                if abs_f(v_mul) < 1000000000000.0 {
                    pool_v = pool_v.push(v_mul)
                    pool_n = pool_n.push("(" + an + "*" + bn + ")")
                }
                // /
                if abs_f(bv) > 0.000000000000001 {
                    let v_div = av / bv
                    if abs_f(v_div) < 1000000000000.0 {
                        pool_v = pool_v.push(v_div)
                        pool_n = pool_n.push("(" + an + "/" + bn + ")")
                    }
                }
                bi = bi + 1
            }
            ai = ai + 1
        }
        d_level = d_level + 1
    }

    println("Expression pool size: " + to_string(pool_v.len()))
    println("")

    // Check against targets
    let mut match_count: i64 = 0
    let mut ti: i64 = 0
    while ti < targets.len() {
        let tparts = targets[ti].split(":")
        let tname = tparts[0]
        let tval = safe_float(tparts[1])

        let mut best_err = 999.0
        let mut best_name = ""
        let mut best_val = 0.0

        let mut ei: i64 = 0
        while ei < pool_v.len() {
            let ev = pool_v[ei]
            if abs_f(tval) > 0.000000000000001 {
                let rel_err = abs_f(ev - tval) / abs_f(tval)
                if rel_err < threshold {
                    if rel_err < best_err {
                        best_err = rel_err
                        best_name = pool_n[ei]
                        best_val = ev
                    }
                }
            }
            ei = ei + 1
        }

        if best_err < threshold {
            let exact_str = if best_err < 0.000000000001 { " [EXACT]" } else { "" }
            println("MATCH: " + tname + " = " + to_string(tval) + " ~ " + best_name + " = " + to_string(best_val) + " (err=" + to_string(best_err * 100.0) + "%)" + exact_str)
            match_count = match_count + 1
        }
        ti = ti + 1
    }

    println("")
    println("Matches found: " + to_string(match_count) + " / " + to_string(targets.len()))
}

// ═══════════════════════════════════════════════════════════
// ─── PHASE 6: ATLAS (simplified) ───
// ═══════════════════════════════════════════════════════════

fn run_atlas(dir: string) {
    println("=== Hypothesis Atlas Scanner ===")
    println("Directory: " + dir)

    // Use exec to list .md files
    let result = exec("ls " + dir + "/*.md 2>/dev/null || echo NONE")
    let lines = result.split("\n")

    if lines.len() == 0 {
        println("No .md files found")
        return
    }
    if lines[0] == "NONE" {
        println("No .md files found")
        return
    }

    let mut count: i64 = 0
    let mut grade_count: i64 = 0
    let mut i: i64 = 0
    while i < lines.len() {
        let filepath = lines[i].trim()
        if filepath.len() > 0 {
            if filepath.contains(".md") {
                // Read file and extract basic metadata
                try {
                    let content = read_file(filepath)
                    let flines = content.split("\n")

                    // Extract title from first heading
                    let mut title = "Untitled"
                    let mut id = "???"
                    let mut grade = ""
                    let mut li: i64 = 0
                    while li < min_i(to_int(to_string(flines.len())), 30) {
                        let line = flines[li]
                        if line.starts_with("# ") {
                            title = line
                        }
                        if line.contains("grade:") || line.contains("Grade:") {
                            grade = line.trim()
                            grade_count = grade_count + 1
                        }
                        if line.contains("H-") {
                            let parts = line.split("H-")
                            if parts.len() > 1 {
                                let id_part = parts[1].split(" ")[0].split(":")[0].split(")")[0]
                                id = "H-" + id_part
                            }
                        }
                        li = li + 1
                    }

                    println("  [" + to_string(count + 1) + "] " + id + " | " + title)
                    if grade != "" {
                        println("       grade: " + grade)
                    }
                    count = count + 1
                } catch e {
                    println("  ERROR reading: " + filepath)
                }
            }
        }
        i = i + 1
    }

    println("")
    println("Total files: " + to_string(count))
    println("With grades: " + to_string(grade_count))
}

