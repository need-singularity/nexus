}

fn run_psi_verify() {
    println("=== PSI Self-Consistency Verification ===")
    let ln2 = 0.693147180559945
    let mut passed: i64 = 0
    let mut total: i64 = 0

    // Check 1: Psi_coupling * 2^5.5 = ln2
    let psi_coupling = ln2 / pow_f(2.0, 5.5)
    let check1 = psi_coupling * pow_f(2.0, 5.5)
    let err1 = abs_f(check1 - ln2)
    let ok1 = err1 < 0.0000000001
    if ok1 { passed = passed + 1 }
    total = total + 1
    println("[" + (if ok1 { "PASS" } else { "FAIL" }) + "] Psi_coupling * 2^5.5 = ln2  (err=" + to_string(err1) + ")")

    // Check 2: 3 / Psi_steps = ln2
    let psi_steps = 3.0 / ln2
    let check2 = 3.0 / psi_steps
    let err2 = abs_f(check2 - ln2)
    let ok2 = err2 < 0.0000000001
    if ok2 { passed = passed + 1 }
    total = total + 1
    println("[" + (if ok2 { "PASS" } else { "FAIL" }) + "] 3 / Psi_steps = ln2  (err=" + to_string(err2) + ")")

    // Check 3: exp(ln2) = 2
    let check3 = exp_f(ln2)
    let err3 = abs_f(check3 - 2.0)
    let ok3 = err3 < 0.0001
    if ok3 { passed = passed + 1 }
    total = total + 1
    println("[" + (if ok3 { "PASS" } else { "FAIL" }) + "] exp(ln2) = 2  (err=" + to_string(err3) + ")")

    // Check 4: Psi_freedom = ln2
    let err4 = abs_f(ln2 - ln2)
    let ok4 = err4 < 0.0000000001
    if ok4 { passed = passed + 1 }
    total = total + 1
    println("[" + (if ok4 { "PASS" } else { "FAIL" }) + "] Psi_freedom = ln2  (err=" + to_string(err4) + ")")

    // Check 5: H -> ln2 convergence (dynamics)
    let mut h = 0.1
    let mut ci: i64 = 0
    while ci < 100 {
        h = h + 0.81 * (ln2 - h)
        ci = ci + 1
    }
    let err5 = abs_f(h - ln2)
    let ok5 = err5 < 0.00000001
    if ok5 { passed = passed + 1 }
    total = total + 1
    println("[" + (if ok5 { "PASS" } else { "FAIL" }) + "] H(100) -> ln2 convergence  (err=" + to_string(err5) + ")")

    // Check 6: sigma(6) = 12
    let s6 = sigma_trial(6)
    let ok6 = s6 == 12
    if ok6 { passed = passed + 1 }
    total = total + 1
    println("[" + (if ok6 { "PASS" } else { "FAIL" }) + "] sigma(6) = 12  (got=" + to_string(s6) + ")")

    // Check 7: 6 is perfect
    let ok7 = sigma_trial(6) == 12
    if ok7 { passed = passed + 1 }
    total = total + 1
    println("[" + (if ok7 { "PASS" } else { "FAIL" }) + "] 6 is perfect  (sigma=2n=" + to_string(2 * 6) + ")")

    println("")
    println("Result: " + to_string(passed) + "/" + to_string(total) + " passed")
}

fn run_conservation(h0: f64, rate: f64) {
    println("=== Conservation Trajectory: H^2 + dH^2 ~ 0.478 ===")
    let ln2 = 0.693147180559945
    let dt = 0.01
    let steps: i64 = 1000

    let mut h = h0
    let mut sum_c = 0.0
    let mut sum_c_sq = 0.0

    println("step\tH\tdH\tconservation")
    let mut step: i64 = 0
    while step < steps {
        let dh = rate * (ln2 - h) * dt
        h = h + dh
        let cons = h * h + dh * dh
        sum_c = sum_c + cons
        sum_c_sq = sum_c_sq + cons * cons

        if step % 100 == 0 {
            println(to_string(step) + "\t" + to_string(h) + "\t" + to_string(dh) + "\t" + to_string(cons))
        }
        step = step + 1
    }

    let mean_c = sum_c / to_float(steps)
    let std_c = sqrt_f(max_f(sum_c_sq / to_float(steps) - mean_c * mean_c, 0.0))

    println("")
    println("Final H:               " + to_string(h))
    println("Mean conservation:     " + to_string(mean_c))
    println("Std conservation:      " + to_string(std_c))
    println("Target:                0.478")
    println("Distance to target:    " + to_string(abs_f(mean_c - 0.478)))
    println("Distance to ln2:       " + to_string(abs_f(h - ln2)))
}

fn run_gate(corpus_mb: f64) {
    println("=== Gate Formula (Law 77) ===")
    println("corpus_mb = " + to_string(corpus_mb))

    if corpus_mb <= 0.0 {
        println("gate = 0.0 (ZERO)")
        return
    }

    // Breakpoints: (threshold, gate, regime)
    let bp_t = [1.0, 10.0, 25.0, 50.0, 100.0, 500.0, 1000.0]
    let bp_g = [0.001, 0.01, 0.1, 0.5, 0.8, 0.95, 1.0]
    let bp_r = ["MICRO", "LOW", "MEDIUM-LOW", "MEDIUM", "HIGH", "FULL", "MAXIMUM"]

    let mut i: i64 = 0
    while i < 7 {
        if corpus_mb <= bp_t[i] {
            if i == 0 {
                println("gate   = " + to_string(bp_g[i]))
                println("regime = " + bp_r[i])
                return
            }
            let prev_t = bp_t[i - 1]
            let prev_g = bp_g[i - 1]
            let log_ratio = ln_f(corpus_mb / prev_t) / ln_f(bp_t[i] / prev_t)
            let mut interp = prev_g + (bp_g[i] - prev_g) * log_ratio
            if interp < 0.0 { interp = 0.0 }
            if interp > 1.0 { interp = 1.0 }
            println("gate   = " + to_string(interp))
            println("regime = " + bp_r[i])
            return
        }
        i = i + 1
    }

    println("gate   = 1.0")
    println("regime = MAXIMUM")
}

fn run_genetic(stops: i64, amino_acids: i64) {
    println("=== Genetic Code n=6 Test ===")
    println("stops=" + to_string(stops) + " amino_acids=" + to_string(amino_acids))

    let n: i64 = 6
    let sigma: i64 = 12
    let tau: i64 = 4
    let phi: i64 = 2
    let sopfr: i64 = 5
    let sense = 64 - stops

    let mut matches: i64 = 0
    let mut total: i64 = 0

    // Universal properties
    println("")
    println("Universal properties:")
    // bases = tau(6) = 4
    let ok_bases = tau == 4
    if ok_bases { matches = matches + 1 }
    total = total + 1
    println("  bases          = 4 = tau(6)  [" + (if ok_bases { "OK" } else { "FAIL" }) + "]")

    // codon_length = n/phi = 3
    let ok_codon = n / phi == 3
    if ok_codon { matches = matches + 1 }
    total = total + 1
    println("  codon_length   = 3 = n/phi   [" + (if ok_codon { "OK" } else { "FAIL" }) + "]")

    // total_codons = 2^n = 64
    let ok_total = 64 == 64
    if ok_total { matches = matches + 1 }
    total = total + 1
    println("  total_codons   = 64 = 2^n    [OK]")

    // reading_frames = n = 6
    matches = matches + 1
    total = total + 1
    println("  reading_frames = 6 = n       [OK]")

    // codon_families = tau^2 = 16
    let ok_fam = tau * tau == 16
    if ok_fam { matches = matches + 1 }
    total = total + 1
    println("  codon_families = 16 = tau^2   [" + (if ok_fam { "OK" } else { "FAIL" }) + "]")

    // base_pairs = phi = 2
    matches = matches + 1
    total = total + 1
    println("  base_pairs     = 2 = phi      [OK]")

    // helix_bp/turn = sopfr*phi = 10
    let ok_helix = sopfr * phi == 10
    if ok_helix { matches = matches + 1 }
    total = total + 1
    println("  helix_bp/turn  = 10 = sopfr*phi [" + (if ok_helix { "OK" } else { "FAIL" }) + "]")

    // minor_groove = sigma = 12
    matches = matches + 1
    total = total + 1
    println("  minor_groove   = 12 = sigma   [OK]")

    // max_degeneracy = n = 6
    matches = matches + 1
    total = total + 1
    println("  max_degeneracy = 6 = n        [OK]")

    // Variable: amino acids
    println("")
    println("Variable properties:")
    total = total + 1
    let mut aa_ok = false
    if tau * sopfr == amino_acids { println("  amino_acids    = " + to_string(amino_acids) + " = tau*sopfr  [OK]")
        aa_ok = true }
    if sigma + tau + n == amino_acids { println("  amino_acids    = " + to_string(amino_acids) + " = sigma+tau+n  [OK]")
        aa_ok = true }
    if sigma * phi - phi == amino_acids { println("  amino_acids    = " + to_string(amino_acids) + " = sigma*phi-phi  [OK]")
        aa_ok = true }
    if aa_ok == false {
        println("  amino_acids    = " + to_string(amino_acids) + " = no_match  [FAIL]")
    } else {
        matches = matches + 1
    }

    // Variable: stop codons
    total = total + 1
    let mut stop_ok = false
    if n / phi == stops { println("  stop_codons    = " + to_string(stops) + " = n/phi  [OK]")
        stop_ok = true }
    if tau == stops { println("  stop_codons    = " + to_string(stops) + " = tau  [OK]")
        stop_ok = true }
    if phi == stops { println("  stop_codons    = " + to_string(stops) + " = phi  [OK]")
        stop_ok = true }
    if 1 == stops { println("  stop_codons    = " + to_string(stops) + " = 1  [OK]")
        stop_ok = true }
    if stop_ok == false {
        println("  stop_codons    = " + to_string(stops) + " = no_match  [FAIL]")
    } else {
        matches = matches + 1
    }

    // Variable: sense codons
    total = total + 1
    let mut sense_ok = false
    if 64 - n / phi == sense { sense_ok = true }
    if 64 - tau == sense { sense_ok = true }
    if 64 - phi == sense { sense_ok = true }
    if sense_ok {
        println("  sense_codons   = " + to_string(sense) + "  [OK]")
        matches = matches + 1
    } else {
        println("  sense_codons   = " + to_string(sense) + "  [FAIL]")
    }

    let pct = to_float(matches) / to_float(total) * 100.0
    println("")
    println("Score: " + to_string(matches) + "/" + to_string(total) + " (" + to_string(pct) + "%)")
}

// ═══════════════════════════════════════════════════════════
// ─── MAIN CLI ───
// ═══════════════════════════════════════════════════════════

fn show_help() {
    println("tecs.hexa — TECS-L Math Acceleration Engine (hexa-native)")
    println("Port of shared/tecsrs/src/*.rs (9 Rust modules)")
    println("")
    println("Usage: hexa tecs.hexa <command> [args]")
    println("")
    println("Commands:")
    println("  sieve <limit> [n]        Arithmetic sieves (sigma,tau,phi,sopfr,omega,lpf)")
    println("  monte <n_trials> [seed]  Texas Sharpshooter Monte Carlo test")
    println("  bootstrap <v1> <v2> ...  Bootstrap CI for mean of given values")
    println("  ode <system> [steps] [dt] ODE attractor (lorenz|rossler|chen|chua|all)")
    println("  grid <size> [threshold]  GZ ratio 3D grid scan")
    println("  perfect <n>              Perfect number analysis + sigma chain")
    println("  search <depth> [thresh]  DFS expression search (default constants)")
    println("  atlas <dir>              Scan hypothesis .md files")
    println("  psi                      PSI consciousness constants")
    println("  psi_verify               PSI self-consistency checks")
    println("  conservation [h0] [rate] Conservation trajectory H^2+dH^2")
    println("  gate <corpus_mb>         Gate formula (Law 77)")
    println("  genetic <stops> <aas>    Genetic code n=6 expressibility test")
    println("  help                     This help text")
}

fn main() {
    let argv = args()
    // argv[0] = hexa binary, argv[1] = script path, argv[2] = command
    if argv.len() < 3 {
        show_help()
        return
    }

    let cmd = argv[2]

    if cmd == "help" || cmd == "--help" || cmd == "-h" {
        show_help()
    } else if cmd == "sieve" {
        let limit: i64 = if argv.len() > 3 { safe_int(argv[3]) } else { 100 }
        let query: i64 = if argv.len() > 4 { safe_int(argv[4]) } else { 0 }
        run_sieve(limit, query)
    } else if cmd == "monte" {
        let n_trials = if argv.len() > 3 { safe_int(argv[3]) } else { 1000 }
        let seed = if argv.len() > 4 { safe_int(argv[4]) } else { 42 }
        // Default real_hits = 8 (typical TECS-L claim count)
        texas_sharpshooter(8, n_trials, seed)
    } else if cmd == "bootstrap" {
        let mut data = []
        let mut i: i64 = 3
        while i < argv.len() {
            data = data.push(safe_float(argv[i]))
            i = i + 1
        }
        if data.len() == 0 {
            println("Usage: hexa tecs.hexa bootstrap <value1> <value2> ...")
        } else {
            bootstrap_ci(data, 5000, 42)
        }
    } else if cmd == "ode" {
        let system = if argv.len() > 3 { argv[3] } else { "lorenz" }
        let steps = if argv.len() > 4 { safe_int(argv[4]) } else { 10000 }
        let dt = if argv.len() > 5 { safe_float(argv[5]) } else { 0.01 }
        run_ode(system, steps, dt)
    } else if cmd == "grid" {
        let grid = if argv.len() > 3 { safe_int(argv[3]) } else { 50 }
        let threshold = if argv.len() > 4 { safe_float(argv[4]) } else { 1.0 }
        run_grid(grid, threshold)
    } else if cmd == "perfect" {
        let n = if argv.len() > 3 { safe_int(argv[3]) } else { 6 }
        run_perfect(n)
    } else if cmd == "search" {
        let depth = if argv.len() > 3 { safe_int(argv[3]) } else { 1 }
        let threshold = if argv.len() > 4 { safe_float(argv[4]) } else { 0.01 }
        run_search(depth, threshold)
    } else if cmd == "atlas" {
        let dir = if argv.len() > 3 { argv[3] } else { "." }
        run_atlas(dir)
    } else if cmd == "psi" {
        run_psi()
    } else if cmd == "psi_verify" {
        run_psi_verify()
    } else if cmd == "conservation" {
        let h0 = if argv.len() > 3 { safe_float(argv[3]) } else { 0.1 }
        let rate = if argv.len() > 4 { safe_float(argv[4]) } else { 0.81 }
        run_conservation(h0, rate)
    } else if cmd == "gate" {
        let corpus_mb = if argv.len() > 3 { safe_float(argv[3]) } else { 50.0 }
        run_gate(corpus_mb)
    } else if cmd == "genetic" {
        let stops = if argv.len() > 3 { safe_int(argv[3]) } else { 3 }
        let aas = if argv.len() > 4 { safe_int(argv[4]) } else { 20 }
        run_genetic(stops, aas)
    } else {
        println("Unknown command: " + cmd)
        println("Run 'hexa tecs.hexa help' for usage.")
    }
}

main()
