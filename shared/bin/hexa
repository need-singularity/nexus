#!/bin/bash
# shared/bin/hexa — hexa 바이너리 resolver (외부 의존 없음)
# 어떤 프로젝트에서도 이 스크립트로 호출하면 자동으로 가용 hexa를 찾아 exec.
# 우선순위: 환경변수 → ~/.hx/bin (gate wrapper) → 로컬 빌드 → ubu/htz fallback
# L0 준수: 전역 ~/.claude 미수정. 모든 hexa 호출이 shared 통과.

set -e

# 1. HEXA_BIN env var override (테스트/디버깅)
if [ -n "$HEXA_BIN" ] && [ -x "$HEXA_BIN" ]; then
    exec "$HEXA_BIN" "$@"
fi

# 2. ~/.hx/bin/hexa (gate wrapper — Ubu/htz 오프로드 포함)
if [ -x "$HOME/.hx/bin/hexa" ]; then
    exec "$HOME/.hx/bin/hexa" "$@"
fi

# 3. 로컬 cargo build (Mac)
for p in \
    "$HOME/Dev/hexa-lang/target/release/hexa" \
    "$HOME/Dev/hexa-lang/target/release/hexa-bin-actual" \
    "$HOME/.cargo/bin/hexa" ; do
    if [ -x "$p" ]; then
        exec "$p" "$@"
    fi
done

# 4. PATH 탐색 (이 스크립트 자신은 shared/bin/hexa로 등록될 수 있어 self-loop 회피)
SELF="$(realpath "$0" 2>/dev/null || echo "$0")"
for cand in $(command -v -a hexa 2>/dev/null); do
    real="$(realpath "$cand" 2>/dev/null || echo "$cand")"
    if [ "$real" != "$SELF" ] && [ -x "$cand" ]; then
        exec "$cand" "$@"
    fi
done

echo "ERROR(shared/bin/hexa): hexa 바이너리 없음. ~/.hx/bin/hexa 또는 ~/Dev/hexa-lang/target/release/hexa 빌드 필요" >&2
exit 127
