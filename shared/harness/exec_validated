#!/bin/bash
# exec_validated — cmd_gate 검증 통과 시에만 엔진 실행
# usage: exec_validated <cmd> "<seed>" <engine_hexa_path> [engine_args...]
#
# 동작:
#   1. hexa run shared/harness/cmd_gate.hexa <cmd> "<seed>" 호출
#   2. stdout "OK:<cmd>:<validated_seed>" → 엔진 exec
#   3. stdout "REJECT:..." 또는 기타 → stderr + exit 2
#
# 왜 bash wrapper 필요:
#   - hexa stage0 exit() 미전파 → stdout prefix 프로토콜
#   - commands.json execution.bash 간결화

set -e

HOME_DIR="${HOME:-/Users/ghost}"
NEXUS_ROOT="${NEXUS:-$HOME_DIR/Dev/nexus}"
HEXA="$NEXUS_ROOT/shared/bin/hexa"
GATE="$NEXUS_ROOT/shared/harness/cmd_gate.hexa"
LOCK_GATE="$NEXUS_ROOT/shared/harness/lock_gate.sh"
HEXA_TIMEOUT="${NEXUS_HEXA_TIMEOUT:-60}"

if [ "$#" -lt 3 ]; then
    echo "usage: exec_validated <cmd> \"<seed>\" <engine.hexa> [args...]" >&2
    exit 2
fi

cmd="$1"
seed="$2"
engine="$3"
shift 3

if [ ! -f "$GATE" ]; then
    echo "ERROR: cmd_gate 부재: $GATE" >&2
    exit 127
fi

# run_hexa: lock(mkdir advisory) + timeout(perl alarm) 적용 hexa 실행
# bypass:  NEXUS_NO_TIMEOUT=1 → 기존 exec 동작
#          NEXUS_NO_LOCK=1    → timeout 만 적용
run_hexa() {
    local engine="$1"; shift
    local base
    base=$(basename "$engine" .hexa)

    # ── blowup 자동 slice 배치 (always-on, NEXUS_NO_SLICE=1 로 비활성) ──
    # blowup*.hexa 는 airgenome-stress.slice (MemoryMax=50%, CPUWeight=10) 안에서 실행.
    # 목적: 다수 claude 동시 blowup → OOM/swap thrash 로 ubu 전체 먹통 방지.
    # Mac (Darwin) 에서는 skip — slice 는 Linux systemd user 전제.
    case "$engine" in
        *blowup*)
            if [ "$(uname)" = "Linux" ] && [ -z "${NEXUS_NO_SLICE:-}" ]; then
                if command -v systemd-run >/dev/null 2>&1; then
                    # claude bash tool env 에는 DBUS_SESSION_BUS_ADDRESS / XDG_RUNTIME_DIR 누락 →
                    # systemd-run --user 가 조용히 실패 → slice 미적용 재현 경로. 명시 주입.
                    : "${XDG_RUNTIME_DIR:=/run/user/$(id -u)}"
                    : "${DBUS_SESSION_BUS_ADDRESS:=unix:path=$XDG_RUNTIME_DIR/bus}"
                    export XDG_RUNTIME_DIR DBUS_SESSION_BUS_ADDRESS
                    # 적용 검증: 실패 시 cgroup.procs 직접 이관으로 fallback
                    if systemd-run --user --scope --quiet \
                        --slice=airgenome-stress.slice \
                        "$HEXA" run "$engine" "$@" 2>/dev/null; then
                        exit $?
                    fi
                    # fallback: cgroup.procs 직접 write + 그냥 exec
                    CG=/sys/fs/cgroup/user.slice/user-$(id -u).slice/user@$(id -u).service/airgenome.slice/airgenome-stress.slice/cgroup.procs
                    [ -w "$CG" ] && echo $$ > "$CG" 2>/dev/null
                    exec "$HEXA" run "$engine" "$@"
                fi
            fi
            ;;
    esac

    # ── enq routing (opt-in: NEXUS_ENQ_BLOWUP=1) — 중앙 slot_cap 직렬화 ──
    if [ "${NEXUS_ENQ_BLOWUP:-0}" = "1" ]; then
        case "$engine" in
            *blowup*)
                local enq_mac="/Users/ghost/Dev/airgenome/bin/enq"
                if [ "$(uname)" = "Darwin" ] && [ -x "$enq_mac" ]; then
                    exec "$enq_mac" heavy -- "$HEXA" run "$engine" "$@"
                fi
                if [ -x "$enq_mac" ]; then
                    local qargs=""
                    local a
                    for a in "$@"; do qargs+=" $(printf '%q' "$a")"; done
                    exec ssh -o ConnectTimeout=5 mac \
                        "$enq_mac heavy -- /Users/ghost/.hx/bin/hexa run $(printf '%q' "$engine")$qargs"
                fi
                ;;
        esac
    fi

    if [ -n "$NEXUS_NO_TIMEOUT" ]; then
        exec "$HEXA" run "$engine" "$@"
    fi

    # lock acquire
    if [ -z "$NEXUS_NO_LOCK" ] && [ -x "$LOCK_GATE" ]; then
        if ! "$LOCK_GATE" acquire "$base" 5; then
            echo "BLOCK: lock_gate — '$base' 이미 실행중 (5s 대기 후 포기)" >&2
            exit 75
        fi
        # shellcheck disable=SC2064
        trap "\"$LOCK_GATE\" release \"$base\" 2>/dev/null" EXIT
    fi

    # timeout via perl alarm
    perl -e '
        use strict; use warnings;
        my $t = shift; my @cmd = @ARGV;
        my $pid = fork(); die "fork: $!" unless defined $pid;
        if ($pid == 0) { exec @cmd; die "exec: $!"; }
        my $timed_out = 0;
        eval {
            local $SIG{ALRM} = sub {
                $timed_out = 1;
                kill "TERM", $pid;
                sleep 5;
                kill "KILL", $pid;
                die "timeout\n";
            };
            alarm $t;
            waitpid($pid, 0);
            alarm 0;
        };
        if ($timed_out || ($@ && $@ =~ /timeout/)) {
            print STDERR "BLOCK: timeout ${t}s — process killed\n";
            exit 124;
        }
        exit($? >> 8);
    ' "$HEXA_TIMEOUT" "$HEXA" run "$engine" "$@"
}

# gate 호출 — set -e 가 cmd substitution 에 전파 안 되므로 exit code 명시 캡처
set +e
gate_out="$("$HEXA" run "$GATE" "$cmd" "$seed" 2>&1)"
gate_rc=$?
set -e

# gate 비정상 종료 + 빈 출력 → silent-exit-0 방지
if [ -z "$gate_out" ]; then
    echo "ERROR: cmd_gate 빈 응답 (rc=$gate_rc) — cmd='$cmd' seed='$seed'" >&2
    exit 2
fi

# 첫 OK: 라인 우선 탐색 (cmd 정규화: free→free_dfs, 돌파→smash 등 대비)
ok_line="$(printf '%s\n' "$gate_out" | grep '^OK:' | head -1)"

case "$gate_out" in
    OK:*)
        # OK:<cmd>:<validated_seed> 파싱 — 첫 줄만 사용 (멀티라인 대응)
        first_line="${gate_out%%$'\n'*}"
        # prefix 가 OK:<caller_cmd>: 와 정확히 매치하지 않아도 OK:<gate_cmd>: 형태면 허용
        validated="${first_line#OK:*:}"
        if [ "$validated" = "$first_line" ]; then
            echo "ERROR: cmd_gate OK 응답 파싱 실패: '$first_line'" >&2
            exit 2
        fi
        # 엔진 실행 (validated seed를 첫 인자로) — timeout+lock 적용
        if [ -f "$engine" ]; then
            run_hexa "$engine" "$validated" "$@"
        else
            echo "ERROR: engine 부재: $engine" >&2
            exit 127
        fi
        ;;
    WARN:*)
        # 경고 통과 — stderr 로깅 후 엔진 실행
        echo "$gate_out" >&2
        # cmd 정규화 대응: caller cmd 일치 grep 실패 시 임의 OK: 라인 fallback
        validated="$(printf '%s\n' "$gate_out" | grep "^OK:$cmd:" | head -1 | sed "s|^OK:$cmd:||")"
        if [ -z "$validated" ] && [ -n "$ok_line" ]; then
            validated="${ok_line#OK:*:}"
        fi
        if [ -n "$validated" ] || [ -z "$seed" ]; then
            run_hexa "$engine" "$validated" "$@"
        else
            echo "ERROR: cmd_gate WARN 응답에 OK: 라인 없음 — seed='$seed'" >&2
            echo "$gate_out" >&2
            exit 2
        fi
        ;;
    REJECT:*)
        echo "$gate_out" >&2
        exit 2
        ;;
    *)
        # cmd_gate 선행 출력(예: ===DECISIONS_BEGIN===...===DECISIONS_END===) 뒤 OK: 대응
        if [ -n "$ok_line" ]; then
            # 선행 출력은 stdout 투과 — Claude dispatcher 가 읽음
            pre_lines="$(printf '%s\n' "$gate_out" | sed -n '1,/^OK:/p' | sed '$d')"
            [ -n "$pre_lines" ] && printf '%s\n' "$pre_lines"
            validated="${ok_line#OK:*:}"
            if [ -f "$engine" ]; then
                run_hexa "$engine" "$validated" "$@"
            else
                echo "ERROR: engine 부재: $engine" >&2
                exit 127
            fi
        else
            echo "$gate_out" >&2
            echo "ERROR: cmd_gate 미지 응답 형식 (rc=$gate_rc) — OK:/WARN:/REJECT: 프리픽스 부재" >&2
            exit 2
        fi
        ;;
esac
