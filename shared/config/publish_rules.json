{
  "_meta": {
    "attr": "publish",
    "project": "_global_fallback",
    "version": 1,
    "inherit": false,
    "updated": "2026-04-18",
    "description": "@publish 글로벌 default — 커밋 메시지 템플릿, push 정책, branch allow list. 프로젝트별 .publish-rules.json 없을 때만 사용."
  },
  "rules": {
    "precondition": {
      "require_doc_zero_violations": true,
      "require_doc_zero_violations_description": "@doc(type=paper) 위반 0 이어야 publish 진행"
    },
    "dirty_check": {
      "allow_only_target_md": true,
      "description": "커밋 직전 repo 가 target md 외에는 clean 이어야 함 — 무관 변경 차단"
    },
    "commit_message": {
      "create_template": "feat({axis}): {name_ko} 도메인 신규 등록 (@publish)",
      "update_template": "chore({axis}): {entry_id} {mk_target} 업데이트 (@publish)",
      "body_lines": [
        "- @doc(type=paper) 위반 0 확인",
        "- domains.json entry id: {entry_id}",
        "- md: {md_rel}",
        "- 자동 실행: @publish(auto=true) attr"
      ],
      "encoding": "utf-8",
      "language": "ko"
    },
    "push": {
      "allowed_branches": ["main"],
      "allowed_branches_description": "push=true 는 이 branch 에서만 허용",
      "default_auto": false,
      "default_push": false,
      "remote": "origin"
    },
    "registry": {
      "path": "/Users/ghost/Dev/nexus/shared/n6/docs/domains.json",
      "path_description": "프로젝트가 자기 레지스트리 경로 override 가능"
    }
  }
}
