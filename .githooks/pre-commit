#!/bin/bash
# H-COMMIT pre-commit wrapper — commit.hexa 에 위임
# 검증 체인: session_lock → git_fresh → lint --staged → commit_fence → peers → broadcast → release
R=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
HEXA="$R/shared/bin/hexa"
COMMIT="$R/shared/harness/commit.hexa"

# R37/AN13/L3-PY: staged .py 우선 차단 (commit.hexa 우회 방어)
# ─── fix 2026-04-19: hexa_stage0 shim lock timeout 시 py_ban_guard rc≠0 → false positive 차단
#     → bash-native staged .py 스캔을 1차로 사용 (hexa 독립). hexa 심화검사는 2차 (lock timeout 관용).
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep -E '\.py$' || true)
if [ -n "$STAGED_PY" ]; then
  echo "[pre-commit] .py ban 위반 — staged .py 감지 (R37/AN13/L3-PY):" >&2
  echo "$STAGED_PY" | sed 's/^/  ✗ /' >&2
  exit 1
fi

PYGUARD="$R/shared/harness/py_ban_guard.hexa"
if [ -x "$HEXA" ] && [ -f "$PYGUARD" ]; then
  PYOUT=$(HEXA_LOCAL=1 "$HEXA" "$PYGUARD" check-staged 2>&1)
  rc=$?
  if [ $rc -ne 0 ]; then
    # hexa shim lock 경합은 병렬 세션 compute 포화 현상 — bash 1차 통과했으면 통과 허용.
    if echo "$PYOUT" | grep -qE "shim: lock timeout|HEXA_LOCAL.*bypass 거부"; then
      echo "[pre-commit] hexa shim lock contention — bash-native staged check 결과로 통과 (R37 bash-side OK)" >&2
    else
      echo "[pre-commit] .py ban 위반 — 커밋 차단 (R37/AN13/L3-PY, hexa deep check)" >&2
      echo "$PYOUT" >&2
      exit $rc
    fi
  fi
fi

[ -x "$HEXA" ] && [ -f "$COMMIT" ] || exit 0
TO=""
command -v timeout >/dev/null 2>&1 && TO="timeout 60"
[ -z "$TO" ] && command -v gtimeout >/dev/null 2>&1 && TO="gtimeout 60"
OUT=$($TO "$HEXA" run "$COMMIT" pre_commit 2>&1)
echo "$OUT"
# fix 2026-04-19: BLOCK 판단 — msg-no-file / COMMIT_EDITMSG 는 pre_commit 단계 구조적 오진 (git 이
# 아직 .git/COMMIT_EDITMSG 를 안 만든 단계). 실제 검증은 commit-msg hook 에서. 나머지 BLOCK 는 차단.
NON_TOLERATED_BLOCK=$(echo "$OUT" | grep -E "__HARNESS_COMMIT_RESULT__ BLOCK" | grep -vE "msg-no-file|COMMIT_EDITMSG" || true)
if [ -n "$NON_TOLERATED_BLOCK" ]; then
  exit 1
fi
if echo "$OUT" | grep -qE "__HARNESS_COMMIT_RESULT__ BLOCK (msg-no-file|COMMIT_EDITMSG)"; then
  echo "[pre-commit] commit.hexa msg-no-file BLOCK → pre_commit 단계 관용 통과 (commit-msg 재검사 수행)" >&2
fi
exit 0
