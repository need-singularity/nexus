#!/bin/bash
# H-COMMIT commit-msg wrapper — prefix 검증 (commit.hexa msg_check 경유)
R=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
HEXA="$R/shared/bin/hexa"
COMMIT="$R/shared/harness/commit.hexa"
[ -x "$HEXA" ] && [ -f "$COMMIT" ] || exit 0
OUT=$(timeout 15 "$HEXA" run "$COMMIT" msg_check "$1" 2>&1)
echo "$OUT" >&2
echo "$OUT" | tail -1 | grep -q "__HARNESS_COMMIT_RESULT__ BLOCK" && exit 1
exit 0
