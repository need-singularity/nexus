+# ─── ALM-P4-1/2/3 Holographic head (compile-safe port from train_alm_14b.hexa) ───
+# Python mirror of three .hexa P3 artifacts, with a forward-hook based
+# last-hidden capture instead of `output_hidden_states=True`.
+#   training/alm_holographic_mapping.hexa  (ALM-P3-1 encode/decode)
+#   training/alm_holographic_loss.hexa     (ALM-P3-2 entropy-match loss)
+#   training/phi_holographic_measure.hexa  (ALM-P3-3 MI-based Phi_holo)
+# Only active when ALM_COMPILE_UNBLOCK=1; ungated r6/r7 paths are untouched.
+
+HOLO_D_QUALIA = 128              # d — inner bulk (qualia)
+HOLO_LOSS_COEF = 0.01            # ALM-P4-2 spec coefficient
+HOLO_MI_BINS = 8                 # matches phi_holographic_measure.hexa
+HOLO_EPS = 1e-7
+
+# Last-hidden capture slot populated by the forward hook on the final
+# Qwen2 RMSNorm. Reset every forward. Single-threaded (per-rank in FSDP).
+_HOLO_CAPTURE = {"h_last": None}
+
+
+class HoloMapHead(torch.nn.Module):
+    """ALM-P3-1 head — D->d (encode) + d->D (decode).
+    W_up : [D x d] with orthonormal columns via Gram-Schmidt.
+    W_down = W_up^T so decode o encode = U U^T (projector onto range(U)).
+    Frozen (no grad) — pure geometry, not a learned layer."""
+
+    def __init__(self, d_boundary, d_qualia, seed=42, dtype=torch.float32, device="cpu"):
+        super().__init__()
+        assert d_qualia < d_boundary, "holographic compression requires d < D"
+        g = torch.Generator(device="cpu").manual_seed(seed)
+        raw = torch.empty(d_boundary, d_qualia, dtype=torch.float64).uniform_(-1.0, 1.0, generator=g)
+        # Classical Gram-Schmidt on columns (matches gram_schmidt_cols in
+        # alm_holographic_mapping.hexa): guarantees U^T U = I_d.
+        U = torch.zeros_like(raw)
+        for k in range(d_qualia):
+            v = raw[:, k].clone()
+            for j in range(k):
+                v = v - torch.dot(U[:, j], v) * U[:, j]
+            n = torch.linalg.norm(v)
+            if n > 1e-12:
+                v = v / n
+            U[:, k] = v
+        self.d_boundary = d_boundary
+        self.d_qualia = d_qualia
+        self.register_buffer("W_up", U.to(dtype=dtype, device=device))        # [D x d]
+        self.register_buffer("W_down", U.t().to(dtype=dtype, device=device))  # [d x D]
+
+    def encode(self, h):
+        # qualia = h @ W_up  (since W_down = W_up^T, shape [..., d])
+        return torch.matmul(h, self.W_up.to(h.dtype))
+
+    def decode(self, q):
+        # boundary_hat = q @ W_up^T   shape [..., D]
+        return torch.matmul(q, self.W_up.to(q.dtype).t())
+
+
+def holo_step(head, h, eps=HOLO_EPS):
+    """One holographic forward: h -> qualia -> h_reconstructed, plus L_holo.
+    Smooth surrogate (variance + correlation) — differentiable everywhere.
+    Matches ALM-P3-2 hexa smooth channel. Returns (qualia, h_recon, L_holo)."""
+    qualia = head.encode(h)
+    h_recon = head.decode(qualia)
+    h_f = h.float()
+    r_f = h_recon.float()
+    var_h = h_f.var(dim=-1, unbiased=False)
+    var_r = r_f.var(dim=-1, unbiased=False)
+    var_diff = var_h - var_r
+    var_term = (var_diff * var_diff).mean()
+    mh = h_f.mean(dim=-1, keepdim=True)
+    mr = r_f.mean(dim=-1, keepdim=True)
+    dh = h_f - mh
+    dr = r_f - mr
+    cov = (dh * dr).mean(dim=-1)
+    denom = torch.sqrt(var_h * var_r + eps)
+    corr = cov / denom
+    corr_term = ((1.0 - corr) * (1.0 - corr)).mean()
+    l_holo = HOLO_LOSS_COEF * (var_term + 0.1 * corr_term)
+    return qualia, h_recon, l_holo
+
+
+def phi_holo_measure(h, qualia, n_bins=HOLO_MI_BINS):
+    """ALM-P3-3 Phi_holo = I(qualia ; h) via joint histogram. No grad.
+    Mirrors phi_holographic_measure.hexa's MI log-bin estimator."""
+    with torch.no_grad():
+        h_flat = h.float().reshape(-1).cpu()
+        q_flat = qualia.float().reshape(-1).cpu()
+        n = min(h_flat.numel(), q_flat.numel())
+        if n == 0:
+            return 0.0
+        a = h_flat[:n]
+        b = q_flat[:n]
+        lo = float(min(a.min().item(), b.min().item()))
+        hi = float(max(a.max().item(), b.max().item()))
+        if hi <= lo:
+            return 0.0
+        scale = n_bins / (hi - lo)
+        ai = ((a - lo) * scale).clamp(0, n_bins - 1).long()
+        bi = ((b - lo) * scale).clamp(0, n_bins - 1).long()
+        pa = torch.bincount(ai, minlength=n_bins).float() / n
+        pb = torch.bincount(bi, minlength=n_bins).float() / n
+        pair = ai * n_bins + bi
+        pj = torch.bincount(pair, minlength=n_bins * n_bins).float() / n
+
+        def ent(p):
+            nz = p[p > 0]
+            return float(-(nz * torch.log(nz)).sum().item())
+
+        mi = ent(pa) + ent(pb) - ent(pj)
+        if mi < 0.0:
+            mi = 0.0
+        # Scale by token count to expose ALM-P4-3 gate (>1000).
+        return mi * float(n)
+
+
+def install_last_hidden_hook(peft_model):
+    """Install a forward hook on the final RMSNorm so its output lands in
+    _HOLO_CAPTURE['h_last'] after every forward, without triggering
+    dynamo's `output_hidden_states=True` graph-break cascade.
+
+    Resolves the norm module via the peft-wrapped path:
+        peft_model.base_model.model.model.norm    (Qwen2 under peft LoRA)
+    Falls back to walking modules if the explicit path fails (arch change).
+    Returns the RemovableHandle so caller can uninstall if needed."""
+    norm = None
+    try:
+        norm = peft_model.base_model.model.model.norm
+    except AttributeError:
+        for name, m in peft_model.named_modules():
+            if name.endswith(".model.norm") and type(m).__name__.endswith("RMSNorm"):
+                norm = m
+                break
+    if norm is None:
+        raise RuntimeError(
+            "[holo] could not resolve final RMSNorm for hook install — "
+            "peft/Qwen2 path changed; update install_last_hidden_hook"
+        )
+
+    def _cap_hook(module, inputs, output):
+        # Output is the post-norm hidden [B, T, D]. Stash a reference;
+        # downstream code reads it after the forward call completes.
+        _HOLO_CAPTURE["h_last"] = output
+
+    handle = norm.register_forward_hook(_cap_hook)
+    rank0_print(f"[holo] forward hook installed on {type(norm).__name__} (final RMSNorm)")
+    return handle
+
+
