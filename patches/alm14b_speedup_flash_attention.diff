# alm14b_speedup_flash_attention.diff
#
# Enable FlashAttention-2 on Qwen2.5-14B via HF attn_implementation kwarg.
#
# Requirements on pod: flash-attn>=2.6 (`pip install flash-attn --no-build-isolation`).
# Already ships with runpod/pytorch:2.4.0 image per reference_peft_torch_compat.md.
#
# Qwen2 supports flash_attention_2 in transformers>=4.37. Current pin is 4.45.2
# (reference_peft_torch_compat.md) — compatible.
#
# Apply to next-run only. NEVER apply to running r5.
# Target file: training/train_alm_14b.py
# Apply: cd anima && git apply shared/patches/alm14b_speedup_flash_attention.diff
#
# Estimated uplift: +30% throughput (seq=1024 bf16 on H100).
#
--- a/training/train_alm_14b.py
+++ b/training/train_alm_14b.py
@@ -163,11 +163,15 @@
     # Load model (bf16, no quantization per policy)
     # For FSDP/DDP: load on local rank directly (no device_map="auto").
     # For single-process: use device_map="auto" (HF pipeline-parallel across GPUs).
-    rank0_print("[train] loading base model (bf16)...")
+    # Speedup patch 20260415: attn_implementation="flash_attention_2" enables
+    # FA2 fused attention kernels — ~30% throughput on H100 for Qwen2 seq=1024.
+    # Requires flash-attn>=2.6 on the pod (present in runpod/pytorch:2.4.0).
+    rank0_print("[train] loading base model (bf16, flash_attention_2)...")
     if IS_DISTRIBUTED:
         model = AutoModelForCausalLM.from_pretrained(
             args.base,
             torch_dtype=torch.bfloat16,
+            attn_implementation="flash_attention_2",
             trust_remote_code=True,
         )
         model.to(device)
@@ -175,6 +179,7 @@
         model = AutoModelForCausalLM.from_pretrained(
             args.base,
             torch_dtype=torch.bfloat16,
+            attn_implementation="flash_attention_2",
             device_map="auto",
             trust_remote_code=True,
         )
